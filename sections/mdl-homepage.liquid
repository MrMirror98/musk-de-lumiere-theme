{{ 'homepage-mdl.css' | asset_url | stylesheet_tag }}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- assign larbre = collections['larbre-de-vie'] -%}
{%- assign essentials = collections['les-essentials'] -%}

<!-- ANNOUNCEMENT -->
<div class="mdl-announcement">
  Complimentary samples with every order &nbsp;·&nbsp;
  <a href="/collections">Discover L'Arbre de Vie →</a>
</div>

<!-- HEADER -->
<div class="mdl-header-wrapper" id="mdl-header">
  <div class="mdl-header">
    <nav><ul class="mdl-nav">
      <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
      <li><a href="/collections/les-essentials">Les Essentials</a></li>
      <li><a href="/collections">Collections</a></li>
      <li><a href="/pages/about">About</a></li>
    </ul></nav>
    <div class="mdl-logo-wrap">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}"
             alt="{{ shop.name }}" width="180" height="68" loading="eager">
      </a>
    </div>
    <div class="mdl-header-icons">
      <a href="{{ routes.search_url }}" class="mdl-header-icon" aria-label="Search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="mdl-header-icon" aria-label="Cart">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="mdl-cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <button class="mdl-hamburger" id="mdl-open" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</div>

<!-- MOBILE DRAWER -->
<div class="mdl-drawer" id="mdl-drawer">
  <button class="mdl-drawer__close" id="mdl-close" aria-label="Close">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <nav><ul>
    <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
    <li><a href="/collections/les-essentials">Les Essentials</a></li>
    <li><a href="/collections">Collections</a></li>
    <li><a href="/pages/about">About</a></li>
    <li><a href="/pages/contact">Contact</a></li>
  </ul></nav>
</div>

<!-- SNAP 1: HERO -->
<section class="mdl-snap mdl-hero">
  <div class="mdl-hero__bg">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 2400 }}"
           alt="" loading="eager" fetchpriority="high">
    {%- else -%}
      <div class="mdl-hero__gradient"></div>
    {%- endif -%}
  </div>
  <div class="mdl-hero__overlay"></div>
  <div class="mdl-hero__content">
    <p class="mdl-hero__eyebrow">Parfums d'Exception</p>
    <h1 class="mdl-hero__title">
      Where Light<br>Becomes <em>Scent</em>
    </h1>
    <p class="mdl-hero__sub">
      Twelve fragrances born from the marriage of French perfumery and ancient oud tradition.
    </p>
    <a href="/collections/larbre-de-vie" class="mdl-hero__cta">
      Explore the Collection <span></span>
    </a>
  </div>
  <div class="mdl-scroll-hint">
    <span>Scroll</span>
    <i></i>
  </div>
</section>

<!-- SNAP 2: L'ARBRE DE VIE -->
<section class="mdl-snap mdl-panel mdl-panel--oud">
  <div class="mdl-panel__bg">
    {%- if section.settings.larbre_image != blank -%}
      <img src="{{ section.settings.larbre_image | image_url: width: 2000 }}" alt="" loading="lazy">
    {%- endif -%}
  </div>
  <div class="mdl-panel__overlay"></div>
  <div class="mdl-panel__content">
    <div class="mdl-panel__num">01</div>
    <p class="mdl-panel__label">Full Collection · 50ml</p>
    <h2 class="mdl-panel__title">L'Arbre<br>de Vie</h2>
    <p class="mdl-panel__desc">Eight fragrances. Oud, leather, rose, amber — the full architecture of a perfume house.</p>
    <span class="mdl-panel__cta">Discover <span></span></span>
  </div>
</section>

<!-- SNAP 3: LES ESSENTIALS -->
<section class="mdl-snap mdl-panel mdl-panel--cream">
  <div class="mdl-panel__bg">
    {%- if section.settings.essentials_image != blank -%}
      <img src="{{ section.settings.essentials_image | image_url: width: 2000 }}" alt="" loading="lazy">
    {%- endif -%}
  </div>
  <div class="mdl-panel__overlay"></div>
  <div class="mdl-panel__content">
    <div class="mdl-panel__num">02</div>
    <p class="mdl-panel__label">Discovery Set · 10ml</p>
    <h2 class="mdl-panel__title">Les<br>Essentials</h2>
    <p class="mdl-panel__desc">Four signatures. The perfect way to begin your journey into Musk de Lumière.</p>
    <span class="mdl-panel__cta">Discover <span></span></span>
  </div>
</section>

<!-- SNAP 4: PRODUCTS -->
<section class="mdl-snap mdl-products-snap">
  <div class="mdl-section-head">
    <div>
      <p class="mdl-eyebrow">The Collection</p>
      <h2 class="mdl-section-title">L'Arbre de Vie</h2>
    </div>
    <a href="/collections/larbre-de-vie" class="mdl-view-all">View All</a>
  </div>
  <div class="mdl-products-grid">
    {%- assign featured = larbre.products -%}
    {%- if featured.size == 0 -%}{%- assign featured = collections.all.products -%}{%- endif -%}
    {%- assign names = "Royale Oud,Chérie Oud,Sultanat Oud,Impériale Oud" | split: "," -%}
    {%- assign notes = "Leather · Oud · Smoke,Oud · Vanilla · Tonka,Powder · Amberwood · Oud,Rose · Velvet · Oud" | split: "," -%}
    {%- for product in featured limit: 4 -%}
      <a href="{{ product.url }}" class="mdl-card">
        <div class="mdl-card__img">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
          {%- else -%}
            <div class="mdl-card__placeholder">{{ product.title }}</div>
          {%- endif -%}
        </div>
        <div class="mdl-card__info">
          <p class="mdl-card__tag">L'Arbre de Vie</p>
          <h3 class="mdl-card__name">{{ product.title }}</h3>
          <p class="mdl-card__sub">{{ product.price | money }}</p>
        </div>
      </a>
    {%- else -%}
      {%- for i in (0..3) -%}
        <div class="mdl-card">
          <div class="mdl-card__img">
            <div class="mdl-card__placeholder">{{ names[i] }}</div>
          </div>
          <div class="mdl-card__info">
            <p class="mdl-card__tag">L'Arbre de Vie</p>
            <h3 class="mdl-card__name">{{ names[i] }}</h3>
            <p class="mdl-card__sub">{{ notes[i] }}</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

<!-- SNAP 5: BRAND STORY -->
<section class="mdl-snap mdl-story">
  <div class="mdl-story__text">
    <p class="mdl-story__eyebrow">The House</p>
    <h2 class="mdl-story__title">
      Born from light.<br>Rooted in <em>tradition.</em>
    </h2>
    <p class="mdl-story__body">
      Musk de Lumière is a fragrance house built on the belief that scent is the closest thing to memory. Drawing from French perfumery tradition and the ancient art of oud, each fragrance is an architecture — composed not worn.
    </p>
    <a href="/pages/about" class="mdl-story__cta">
      Our Story <span></span>
    </a>
  </div>
  <div class="mdl-story__img">
    {%- if section.settings.story_image != blank -%}
      <img src="{{ section.settings.story_image | image_url: width: 1000 }}" alt="" loading="lazy">
    {%- else -%}
      <div class="mdl-story__img-placeholder">Campaign Image</div>
    {%- endif -%}
  </div>
</section>

<!-- SNAP 6: NEWSLETTER + FOOTER -->
<section class="mdl-snap mdl-last-snap">
  <div class="mdl-newsletter">
    <p class="mdl-newsletter__eyebrow">The Inner Circle</p>
    <h2 class="mdl-newsletter__title">First Access. Always.</h2>
    <p class="mdl-newsletter__sub">New collections, exclusive releases, and the art behind the scent.</p>
    {%- form 'customer', id: 'mdl-newsletter' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="mdl-newsletter__form">
        <input class="mdl-newsletter__input" type="email"
               name="contact[email]" placeholder="Your email address"
               required autocomplete="email">
        <button type="submit" class="mdl-newsletter__btn">Subscribe</button>
      </div>
    {%- endform -%}
  </div>
  <div class="mdl-footer">
    <div>
      <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}" alt="{{ shop.name }}" width="120" height="48">
      <p class="mdl-footer__tag">A fragrance house born from light and rooted in the art of perfumery.</p>
      <div class="mdl-footer__social">
        {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}">Instagram</a>{%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}<a href="{{ settings.social_tiktok_link }}">TikTok</a>{%- endif -%}
      </div>
    </div>
    <div class="mdl-footer__col"><h4>Collections</h4><ul>
      <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
      <li><a href="/collections/les-essentials">Les Essentials</a></li>
      <li><a href="/collections">All Fragrances</a></li>
    </ul></div>
    <div class="mdl-footer__col"><h4>The House</h4><ul>
      <li><a href="/pages/about">Our Story</a></li>
      <li><a href="/pages/contact">Contact</a></li>
    </ul></div>
    <div class="mdl-footer__col"><h4>Information</h4><ul>
      <li><a href="/policies/shipping-policy">Shipping</a></li>
      <li><a href="/policies/refund-policy">Returns</a></li>
      <li><a href="/policies/privacy-policy">Privacy</a></li>
    </ul></div>
  </div>
  <div class="mdl-footer__bottom">
    <span class="mdl-footer__copy">© {{ 'now' | date: '%Y' }} Musk de Lumière. All rights reserved.</span>
    <span class="mdl-footer__copy">Parsippany, NJ · muskdelumiere.com</span>
  </div>
</section>

<script>
(function(){
  const header = document.getElementById('mdl-header');
  window.addEventListener('scroll', function(){
    header.classList.toggle('scrolled', window.scrollY > 80);
  }, {passive:true});
  document.getElementById('mdl-open').addEventListener('click', function(){
    document.getElementById('mdl-drawer').classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  function close(){
    document.getElementById('mdl-drawer').classList.remove('open');
    document.body.style.overflow = '';
  }
  document.getElementById('mdl-close').addEventListener('click', close);
  document.querySelectorAll('.mdl-drawer a').forEach(function(a){ a.addEventListener('click', close); });
  // Make collection panels clickable
  document.querySelectorAll('.mdl-panel').forEach(function(p){
    p.addEventListener('click', function(){
      const link = p.getAttribute('href') || p.querySelector('a')?.getAttribute('href');
      if(link) window.location.href = link;
    });
  });
})();
</script>

{% schema %}
{
  "name": "MDL Homepage",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero background image" },
    { "type": "image_picker", "id": "larbre_image", "label": "L'Arbre de Vie image" },
    { "type": "image_picker", "id": "essentials_image", "label": "Les Essentials image" },
    { "type": "image_picker", "id": "story_image", "label": "Brand story image" }
  ],
  "presets": [{ "name": "MDL Homepage" }]
}
{% endschema %}
