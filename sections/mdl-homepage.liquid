{{ 'homepage-mdl.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

{%- assign larbre = collections['larbre-de-vie'] -%}
{%- assign essentials = collections['les-essentials'] -%}
{%- assign discovery_handle = "discovery-set-larbre-de-vie" -%}
{%- assign discovery_product = all_products[discovery_handle] -%}
{%- assign essential_handles = "prism,bel-homme,madam-alece,fleur-rouge" | split: "," -%}

<!-- GLASS ANNOUNCEMENT BAR -->
<div class="mdl-bar" id="mdl-bar">
  Complimentary samples with every order &nbsp;·&nbsp;
  <a href="/collections/larbre-de-vie">&nbsp;Discover L'Arbre de Vie →</a>
</div>

<!-- HEADER -->
<header class="mdl-header" id="mdl-header" role="banner">
  <!-- Burger: sibling (not child of icons) so absolute positioning works -->
  <button class="mdl-header__burger" id="mdl-burger" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <nav class="mdl-header__nav-wrap" role="navigation" aria-label="Primary">
    <ul class="mdl-header__nav">
      <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
      <li><a href="/collections/les-essentials">Les Essentials</a></li>
      <li><a href="/collections">Maison</a></li>
      <li><a href="/pages/about">L'Histoire</a></li>
    </ul>
  </nav>

  <div class="mdl-header__logo">
    <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
      <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}"
           alt="{{ shop.name }}" width="320" height="130" loading="eager" fetchpriority="high">
    </a>
  </div>

  <div class="mdl-header__icons">
    <button class="mdl-header__icon" id="mdl-search-open" aria-label="Search">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
    </button>
    <button class="mdl-header__icon" id="mdl-cart-open" aria-label="Cart">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="mdl-cart-bubble" id="mdl-cart-count" {% if cart.item_count == 0 %}style="display:none"{% endif %}>{{ cart.item_count }}</span>
    </button>
  </div>
</header>

<!-- SLIDE NUMBER -->
<div class="mdl-slide-num" id="mdl-slidenum">
  <span class="mdl-slide-num__cur" id="mdl-cur">01</span>
  <span class="mdl-slide-num__tot">/ 07</span>
</div>

<!-- MOBILE NAV DRAWER — dropdown menu -->
<nav class="mdl-drawer" id="mdl-drawer" aria-label="Mobile navigation" aria-hidden="true">
  <button class="mdl-drawer__close" id="mdl-close" aria-label="Close menu">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <div class="mdl-drawer__inner">
    <div class="mdl-drawer__logo">
      <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}" alt="Musk de Lumière" width="140" height="60">
    </div>

    <!-- L'ARBRE DE VIE -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label"><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></h4>

      <!-- The Roots dropdown -->
      <div class="mdl-drop">
        <button class="mdl-drop__toggle" aria-expanded="false" aria-controls="drop-roots">
          <span class="mdl-drop__title">The Roots <em class="mdl-drop__hint">De Bois</em></span>
          <svg class="mdl-drop__chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mdl-drop__body" id="drop-roots">
          <ul>
            {%- assign p1 = all_products['royale-oud'] -%}
            <li><a href="{% if p1 != blank and p1.id %}{{ p1.url }}{% else %}/collections/larbre-de-vie{% endif %}">Royale Oud</a></li>
            {%- assign p2 = all_products['cherie-oud'] -%}
            <li><a href="{% if p2 != blank and p2.id %}{{ p2.url }}{% else %}/collections/larbre-de-vie{% endif %}">Chérie Oud</a></li>
            {%- assign p3 = all_products['sultanat-oud'] -%}
            <li><a href="{% if p3 != blank and p3.id %}{{ p3.url }}{% else %}/collections/larbre-de-vie{% endif %}">Sultanat Oud</a></li>
            {%- assign p4 = all_products['imperiale-oud'] -%}
            <li><a href="{% if p4 != blank and p4.id %}{{ p4.url }}{% else %}/collections/larbre-de-vie{% endif %}">Impériale Oud</a></li>
            <li><a href="/collections/larbre-de-vie" class="mdl-drop__all">View all Roots <span>→</span></a></li>
          </ul>
        </div>
      </div>

      <!-- The Light dropdown -->
      <div class="mdl-drop">
        <button class="mdl-drop__toggle" aria-expanded="false" aria-controls="drop-light">
          <span class="mdl-drop__title">The Light <em class="mdl-drop__hint">Les Branches</em></span>
          <svg class="mdl-drop__chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mdl-drop__body" id="drop-light">
          <ul>
            {%- assign l1 = all_products['paradis-de-bleu'] -%}
            <li><a href="{% if l1 != blank and l1.id %}{{ l1.url }}{% else %}/collections/larbre-de-vie{% endif %}">Paradis de Bleu</a></li>
            {%- assign l2 = all_products['neroli-de-nuit'] -%}
            <li><a href="{% if l2 != blank and l2.id %}{{ l2.url }}{% else %}/collections/larbre-de-vie{% endif %}">Néroli de Nuit</a></li>
            {%- assign l3 = all_products['hayal'] -%}
            <li><a href="{% if l3 != blank and l3.id %}{{ l3.url }}{% else %}/collections/larbre-de-vie{% endif %}">Hayal</a></li>
            {%- assign l4 = all_products['rosee-blanche'] -%}
            <li><a href="{% if l4 != blank and l4.id %}{{ l4.url }}{% else %}/collections/larbre-de-vie{% endif %}">Rosée Blanche</a></li>
            <li><a href="/collections/larbre-de-vie" class="mdl-drop__all">View all Light <span>→</span></a></li>
          </ul>
        </div>
      </div>

      <!-- Discovery Set direct link -->
      <ul class="mdl-drawer__direct">
        {%- assign ds = all_products['discovery-set-larbre-de-vie'] -%}
        <li><a href="{% if ds != blank and ds.id %}{{ ds.url }}{% else %}/collections/larbre-de-vie{% endif %}">Discovery Set <em class="mdl-drawer__hint">8 × 2.5ml</em></a></li>
      </ul>
    </section>

    <!-- LES ESSENTIALS -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label"><a href="/collections/les-essentials">Les Essentials</a></h4>

      <div class="mdl-drop">
        <button class="mdl-drop__toggle" aria-expanded="false" aria-controls="drop-everyday">
          <span class="mdl-drop__title">Everyday <em class="mdl-drop__hint">10ml & 100ml</em></span>
          <svg class="mdl-drop__chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mdl-drop__body" id="drop-everyday">
          <ul>
            {%- assign e1 = all_products['prism'] -%}
            <li><a href="{% if e1 != blank and e1.id %}{{ e1.url }}{% else %}/collections/les-essentials{% endif %}">Prism</a></li>
            {%- assign e2 = all_products['bel-homme'] -%}
            <li><a href="{% if e2 != blank and e2.id %}{{ e2.url }}{% else %}/collections/les-essentials{% endif %}">Bel Homme</a></li>
            {%- assign e3 = all_products['madam-alece'] -%}
            <li><a href="{% if e3 != blank and e3.id %}{{ e3.url }}{% else %}/collections/les-essentials{% endif %}">Madam Alece</a></li>
            {%- assign e4 = all_products['fleur-rouge'] -%}
            <li><a href="{% if e4 != blank and e4.id %}{{ e4.url }}{% else %}/collections/les-essentials{% endif %}">Fleur Rouge</a></li>
            <li><a href="/collections/les-essentials" class="mdl-drop__all">View all Essentials <span>→</span></a></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- COMING SOON -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label">Coming Soon</h4>
      <ul class="mdl-drawer__direct">
        <li><span class="mdl-drawer__coming">Essentials Quartet · 4 × 10ml <em>Soon</em></span></li>
        <li><span class="mdl-drawer__coming">Gift Sets <em>Soon</em></span></li>
        <li><span class="mdl-drawer__coming">Home Fragrances <em>Soon</em></span></li>
      </ul>
    </section>

    <!-- MAISON -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label">Maison</h4>
      <ul class="mdl-drawer__direct">
        <li><a href="/pages/about">Our Story <em class="mdl-drawer__hint">L'Histoire</em></a></li>
        <li><a href="/pages/the-craft">The Craft</a></li>
        <li><a href="/pages/journal">Journal</a></li>
        <li><a href="/pages/contact">Contact</a></li>
      </ul>
    </section>

    <!-- SERVICE -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label">Service</h4>
      <ul class="mdl-drawer__direct">
        <li><a href="/policies/shipping-policy">Shipping</a></li>
        <li><a href="/policies/refund-policy">Returns</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
      </ul>
    </section>

    <!-- LEGAL -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label">Legal</h4>
      <ul class="mdl-drawer__legal">
        <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
        <li><a href="/policies/terms-of-service">Terms of Service</a></li>
      </ul>
    </section>

    <!-- ACCOUNT + CART -->
    <div class="mdl-drawer__foot">
      <a href="/account" class="mdl-drawer__util">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
        Account
      </a>
      <a href="/cart" class="mdl-drawer__util">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Cart <span class="mdl-drawer__util-count">({{ cart.item_count }})</span>
      </a>
    </div>
  </div>
</nav>

<!-- SEARCH OVERLAY -->
<div class="mdl-search-overlay" id="mdl-search">
  <button class="mdl-search-overlay__close" id="mdl-search-close" aria-label="Close search">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <form class="mdl-search-overlay__form" action="/search" method="get">
    <input type="hidden" name="type" value="product">
    <input class="mdl-search-overlay__input" type="search" name="q" placeholder="Search the Maison..." autocomplete="off" id="mdl-search-input">
  </form>
  <div class="mdl-search-overlay__results">
    <p class="mdl-search-overlay__hint" id="mdl-search-hint">Start typing to discover fragrances</p>
    <div id="mdl-search-results"></div>
  </div>
</div>

<!-- CART DRAWER -->
<div class="mdl-cart-drawer__overlay" id="mdl-cart-overlay"></div>
<aside class="mdl-cart-drawer" id="mdl-cart-drawer">
  <div class="mdl-cart-drawer__head">
    <h2 class="mdl-cart-drawer__title">Your Cart</h2>
    <button class="mdl-cart-drawer__close" id="mdl-cart-close" aria-label="Close cart">
      <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="mdl-cart-drawer__body" id="mdl-cart-body">
    <div class="mdl-cart-drawer__empty">
      <p>Your cart awaits.</p>
      <a href="/collections/larbre-de-vie">Discover the Maison →</a>
    </div>
  </div>
  <div class="mdl-cart-drawer__foot" id="mdl-cart-foot" style="display:none;">
    <div class="mdl-cart-drawer__total">
      <span class="mdl-cart-drawer__total-label">Subtotal</span>
      <span class="mdl-cart-drawer__total-amount" id="mdl-cart-total">$0.00</span>
    </div>
    <a href="/checkout" class="mdl-cart-drawer__checkout">Checkout</a>
  </div>
</aside>

<!-- ============================================
     SWIPER — 7 SLIDES
============================================ -->
<div class="mdl-swiper-wrap">
  <div class="swiper mdl-swiper" id="mdl-swiper">
    <div class="swiper-wrapper">

      <!-- SLIDE 1: VIDEO HERO -->
      <div class="swiper-slide s-hero" data-mode="dark">
        <div class="s-hero__media">
          {%- if section.settings.hero_video != blank -%}
            <video autoplay muted loop playsinline poster="{% if section.settings.hero_image != blank %}{{ section.settings.hero_image | image_url: width: 1600 }}{% endif %}">
              <source src="{{ section.settings.hero_video }}" type="video/mp4">
            </video>
          {%- elsif section.settings.hero_image != blank -%}
            <img src="{{ section.settings.hero_image | image_url: width: 2400 }}" alt="">
          {%- else -%}
            <div class="s-hero__media-fallback"></div>
          {%- endif -%}
        </div>
        <div class="s-hero__overlay"></div>
        <div class="s-hero__content">
          <p class="s-eyebrow">Une Maison de Parfumerie</p>
          <h1 class="s-hero__h1">The Art of <em>Parfumerie</em></h1>
          <p class="s-hero__sub">Twelve fragrances. Eight oud-rooted signatures. Four everyday creations. One Maison.</p>
          <a href="/collections/larbre-de-vie" class="s-cta">
            Discover L'Arbre de Vie <span class="s-cta__line"></span>
          </a>
        </div>
        <div class="s-scroll">
          <span class="s-scroll__txt">Slide</span>
          <svg class="s-scroll__arrow" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </div>
      </div>

      <!-- SLIDE 2: DISCOVERY — writings IN FRONT of image -->
      <div class="swiper-slide s-showcase s-showcase--dark" data-mode="dark">
        <div class="s-showcase__bg">
          {%- if section.settings.discovery_image != blank -%}
            <img src="{{ section.settings.discovery_image | image_url: width: 2400 }}" alt="L'Arbre de Vie Discovery Set — 8 signatures 2.5ml each" loading="lazy">
          {%- elsif discovery_product != blank and discovery_product.featured_image -%}
            <img src="{{ discovery_product.featured_image | image_url: width: 2400 }}" alt="L'Arbre de Vie Discovery Set" loading="lazy">
          {%- else -%}
            <div class="s-showcase__bg s-showcase__bg--gradient-dark" style="position:absolute;inset:0;"></div>
          {%- endif -%}
        </div>
        <div class="s-showcase__overlay"></div>
        <div class="s-showcase__title-wrap">
          <p class="s-showcase__chapter">02 — Le Coffret</p>
          <h2 class="s-showcase__title">The <em>Discovery</em>.</h2>
          <p class="s-showcase__lead">Begin your journey through the Maison. The L'Arbre de Vie Discovery Set holds the eight signatures in miniature — the full architecture of the tree, in your hands.</p>
        </div>
        <div class="s-showcase__num"><em>02</em>/ 07</div>
        {%- if discovery_product != blank and discovery_product.id -%}
          <a href="{{ discovery_product.url }}" class="s-popup" aria-label="Shop the L'Arbre de Vie Discovery Set">
        {%- else -%}
          <a href="/collections/larbre-de-vie" class="s-popup" aria-label="Explore L'Arbre de Vie collection">
        {%- endif -%}
          <div class="s-popup__img">
            {%- if section.settings.discovery_image != blank -%}
              <img src="{{ section.settings.discovery_image | image_url: width: 300 }}" alt="">
            {%- elsif discovery_product != blank and discovery_product.featured_image -%}
              <img src="{{ discovery_product.featured_image | image_url: width: 300 }}" alt="">
            {%- else -%}
              <div class="s-popup__img-placeholder">Coffret</div>
            {%- endif -%}
          </div>
          <div class="s-popup__content">
            <p class="s-popup__tag">L'Arbre de Vie</p>
            <h3 class="s-popup__name">Discovery Set</h3>
            <p class="s-popup__sub">Eight signatures · 2.5ml each</p>
            <span class="s-popup__cta">Explore the Collection <span class="s-popup__cta-line"></span></span>
          </div>
        </a>
      </div>

      <!-- SLIDE 3: THE LIGHT — writings IN FRONT of image (now before Roots) -->
      <div class="swiper-slide s-showcase s-showcase--light" data-mode="light">
        <div class="s-showcase__bg">
          {%- if section.settings.light_image != blank -%}
            <img src="{{ section.settings.light_image | image_url: width: 2400 }}" alt="Les Branches — floral fragrances" loading="lazy">
          {%- else -%}
            <div class="s-showcase__bg s-showcase__bg--gradient-light" style="position:absolute;inset:0;"></div>
          {%- endif -%}
        </div>
        <div class="s-showcase__overlay"></div>
        <div class="s-showcase__title-wrap">
          <p class="s-showcase__chapter">03 — Les Branches</p>
          <h2 class="s-showcase__title">The <em>Light</em>.</h2>
          <p class="s-showcase__lead">From the canopy. Néroli at midnight, white rose, oceanic blue, the dream of Hayal — the Maison's lighter expressions, where the tree reaches for the sun.</p>
        </div>
        <div class="s-showcase__num"><em>03</em>/ 07</div>
        <a href="/collections/larbre-de-vie" class="s-popup" aria-label="Explore Les Branches — The Light">
          <div class="s-popup__img">
            {%- if section.settings.light_popup_image != blank -%}
              <img src="{{ section.settings.light_popup_image | image_url: width: 300 }}" alt="">
            {%- else -%}
              <div class="s-popup__img-placeholder">Les Branches</div>
            {%- endif -%}
          </div>
          <div class="s-popup__content">
            <p class="s-popup__tag">L'Arbre de Vie</p>
            <h3 class="s-popup__name">Les Branches</h3>
            <p class="s-popup__sub">Paradis · Néroli · Hayal · Rosée</p>
            <span class="s-popup__cta">Explore the Light <span class="s-popup__cta-line"></span></span>
          </div>
        </a>
      </div>

      <!-- SLIDE 4: THE ROOTS — writings IN FRONT of image -->
      <div class="swiper-slide s-showcase s-showcase--dark" data-mode="dark">
        <div class="s-showcase__bg">
          {%- if section.settings.roots_image != blank -%}
            <img src="{{ section.settings.roots_image | image_url: width: 2400 }}" alt="Les Racines — oud fragrances" loading="lazy">
          {%- else -%}
            <div class="s-showcase__bg s-showcase__bg--gradient-dark" style="position:absolute;inset:0;"></div>
          {%- endif -%}
        </div>
        <div class="s-showcase__overlay"></div>
        <div class="s-showcase__title-wrap">
          <p class="s-showcase__chapter">04 — Les Racines</p>
          <h2 class="s-showcase__title">The <em>Roots</em>.</h2>
          <p class="s-showcase__lead">From the base of the tree. Heavy, smoke-laden, leather-warm — the four oud-rooted signatures that form the architecture of the Maison's deepest creations.</p>
        </div>
        <div class="s-showcase__num"><em>04</em>/ 07</div>
        <a href="/collections/larbre-de-vie" class="s-popup" aria-label="Explore Les Racines — The Roots">
          <div class="s-popup__img">
            {%- if section.settings.roots_popup_image != blank -%}
              <img src="{{ section.settings.roots_popup_image | image_url: width: 300 }}" alt="">
            {%- else -%}
              <div class="s-popup__img-placeholder">Les Racines</div>
            {%- endif -%}
          </div>
          <div class="s-popup__content">
            <p class="s-popup__tag">L'Arbre de Vie</p>
            <h3 class="s-popup__name">Les Racines</h3>
            <p class="s-popup__sub">Royale · Chérie · Sultanat · Impériale</p>
            <span class="s-popup__cta">Explore the Roots <span class="s-popup__cta-line"></span></span>
          </div>
        </a>
      </div>

      <!-- SLIDE 5: LES ESSENTIALS — Everyday Grid -->
      <div class="swiper-slide s-collection" data-mode="dark">
        <div class="s-collection__head">
          <div class="s-collection__head-left">
            <p class="s-collection__eyebrow">05 — Le Quotidien</p>
            <h2 class="s-collection__title">For <em>every day</em>.</h2>
            <p class="s-collection__sub">Four magnificent everyday creations. Lighter, fresher, accessible — the Maison's signatures distilled for modern living. Available in 10ml and 100ml.</p>
          </div>
          <a href="/collections/les-essentials" class="s-view-all">View All</a>
        </div>
        <div class="s-grid">
          {%- assign ess_names = "Prism,Bel Homme,Madam Alece,Fleur Rouge" | split: "," -%}
          {%- for h in essential_handles -%}
            {%- assign p = all_products[h] -%}
            {%- if p != blank and p.id -%}
              <a href="{{ p.url }}" class="s-card" aria-label="{{ p.title }} — Les Essentials">
                <div class="s-card__img">
                  {%- if p.featured_image -%}
                    <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title }} by Musk de Lumière" loading="lazy">
                  {%- else -%}
                    <div class="s-card__placeholder">
                      <em>Les Essentials</em>
                      <strong>{{ p.title }}</strong>
                    </div>
                  {%- endif -%}
                </div>
                <div class="s-card__info">
                  <p class="s-card__tag">Les Essentials</p>
                  <h3 class="s-card__name">{{ p.title }}</h3>
                  <p class="s-card__price">{{ p.price | money }}</p>
                </div>
              </a>
            {%- else -%}
              <div class="s-card">
                <div class="s-card__img">
                  <div class="s-card__placeholder">
                    <em>Les Essentials</em>
                    <strong>{{ ess_names[forloop.index0] }}</strong>
                  </div>
                </div>
                <div class="s-card__info">
                  <p class="s-card__tag">Les Essentials</p>
                  <h3 class="s-card__name">{{ ess_names[forloop.index0] }}</h3>
                  <p class="s-card__price">Coming Soon</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <!-- SLIDE 6: BRAND STORY -->
      <div class="swiper-slide" data-mode="dark">
        <div class="s-story">
          <div class="s-story__left">
            <p class="s-story__eyebrow">06 — L'Histoire de la Maison</p>
            <h2 class="s-story__title">A house built on <em>memory.</em></h2>
            <p class="s-story__body">Musk de Lumière is a fragrance house built on the belief that scent is the closest thing to memory. From our atelier in New Jersey, we draw from French perfumery tradition and the ancient heritage of oud — composing each fragrance not to be worn, but to be lived in.</p>
            <a href="/pages/about" class="s-story__link">Read Our Story <span></span></a>
          </div>
          <div class="s-story__right">
            {%- if section.settings.story_image != blank -%}
              <img src="{{ section.settings.story_image | image_url: width: 1000 }}" alt="" loading="lazy">
            {%- else -%}
              <div class="s-story__placeholder">Maison Image</div>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- SLIDE 7: NEWSLETTER + FOOTER -->
      <div class="swiper-slide s-last" data-mode="light">
        <div class="s-newsletter">
          <p class="s-newsletter__eyebrow">07 — Le Cercle Privé</p>
          <h2 class="s-newsletter__title">Where Light Begins.</h2>
          <p class="s-newsletter__sub">First access to new releases, private events, and the rituals of the Maison.</p>
          {%- form 'customer', id: 'mdl-nl' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="s-newsletter__form">
              <input class="s-newsletter__input" type="email" name="contact[email]" placeholder="Your email address" required>
              <button type="submit" class="s-newsletter__btn">Subscribe</button>
            </div>
          {%- endform -%}
        </div>
        <div class="s-footer">
          <div>
            <img class="s-footer__logo" src="{{ 'logo-musk-de-lumiere.png' | asset_url }}" alt="{{ shop.name }}">
            <p class="s-footer__tag">Une maison de parfumerie. Born in New Jersey, rooted in tradition.</p>
            <div class="s-footer__social">
              {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener">Instagram</a>{%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}<a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener">TikTok</a>{%- endif -%}
            </div>
          </div>
          <div class="s-footer__col"><h4>La Maison</h4><ul>
            <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
            <li><a href="/collections/les-essentials">Les Essentials</a></li>
            <li><a href="/collections">All Fragrances</a></li>
          </ul></div>
          <div class="s-footer__col"><h4>L'Histoire</h4><ul>
            <li><a href="/pages/about">Our Story</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          </ul></div>
          <div class="s-footer__col"><h4>Information</h4><ul>
            <li><a href="/policies/shipping-policy">Shipping</a></li>
            <li><a href="/policies/refund-policy">Returns</a></li>
            <li><a href="/policies/privacy-policy">Privacy</a></li>
          </ul></div>
        </div>
        <div class="s-footer__bottom">
          <span class="s-footer__copy">© {{ 'now' | date: '%Y' }} Musk de Lumière. All rights reserved.</span>
          <span class="s-footer__copy">Parsippany, NJ · muskdelumiere.com</span>
        </div>
      </div>

    </div>
    <div class="swiper-pagination"></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
(function(){
  const header = document.getElementById('mdl-header');
  const bar = document.getElementById('mdl-bar');
  const counter = document.getElementById('mdl-cur');
  const slidenum = document.getElementById('mdl-slidenum');
  const swiperEl = document.getElementById('mdl-swiper');

  /* ========== iOS viewport fix ==========
     Set --mdl-vh to the REAL pixel height so slides match the visible area
     regardless of Safari chrome state. */
  function setVh(){
    document.documentElement.style.setProperty('--mdl-vh', window.innerHeight + 'px');
  }
  setVh();
  let vhTimer;
  window.addEventListener('resize', function(){
    clearTimeout(vhTimer);
    vhTimer = setTimeout(function(){
      setVh();
      if(window.mdlSwiper) window.mdlSwiper.update();
    }, 80);
  });
  window.addEventListener('orientationchange', function(){
    setTimeout(function(){
      setVh();
      if(window.mdlSwiper) window.mdlSwiper.update();
    }, 250);
  });

  const isMobile = window.matchMedia('(max-width: 1024px)').matches;
  const swiper = window.mdlSwiper = new Swiper('#mdl-swiper', {
    direction: 'vertical',
    slidesPerView: 1,
    speed: isMobile ? 700 : 1000,
    mousewheel: { sensitivity: 1, thresholdDelta: 40, releaseOnEdges: true },
    keyboard: { enabled: true },
    touchReleaseOnEdges: true,
    threshold: 8,
    longSwipesRatio: 0.18,
    longSwipesMs: 200,
    pagination: { el: '.swiper-pagination', clickable: true },
    on: {
      slideChange: function() {
        const n = String(this.activeIndex + 1).padStart(2,'0');
        if(counter) counter.textContent = n;
        const slide = this.slides[this.activeIndex];
        const mode = slide.getAttribute('data-mode') || 'dark';
        if(this.activeIndex === 0) {
          header.classList.remove('solid', 'light-mode');
          bar.classList.remove('bar-light');
        } else {
          header.classList.add('solid');
          if(mode === 'light') {
            header.classList.add('light-mode');
            bar.classList.add('bar-light');
            swiperEl.classList.add('pagination-light');
            slidenum.classList.add('light');
          } else {
            header.classList.remove('light-mode');
            bar.classList.remove('bar-light');
            swiperEl.classList.remove('pagination-light');
            slidenum.classList.remove('light');
          }
        }
      }
    }
  });

  // Mobile drawer
  document.getElementById('mdl-burger').addEventListener('click', function(){
    document.getElementById('mdl-drawer').classList.add('open');
    document.body.style.overflow = 'hidden';
    swiper.mousewheel.disable();
  });
  function closeDrawer(){
    document.getElementById('mdl-drawer').classList.remove('open');
    document.body.style.overflow = '';
    swiper.mousewheel.enable();
  }
  document.getElementById('mdl-close').addEventListener('click', closeDrawer);
  document.querySelectorAll('.mdl-drawer a').forEach(a => a.addEventListener('click', closeDrawer));

  // ====== DROPDOWN ACCORDIONS IN MENU ======
  document.querySelectorAll('.mdl-drop__toggle').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      const targetId = btn.getAttribute('aria-controls');
      const body = document.getElementById(targetId);
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      btn.setAttribute('aria-expanded', !isOpen);
      if(!isOpen){
        body.classList.add('open');
        // set max-height to actual content height for smooth animation
        body.style.maxHeight = body.scrollHeight + 'px';
      } else {
        body.style.maxHeight = '0';
        body.addEventListener('transitionend', function h(){
          body.classList.remove('open');
          body.removeEventListener('transitionend', h);
        });
      }
    });
  });


  // SEARCH
  const searchOverlay = document.getElementById('mdl-search');
  const searchInput = document.getElementById('mdl-search-input');
  const searchResults = document.getElementById('mdl-search-results');
  const searchHint = document.getElementById('mdl-search-hint');
  let searchTimer = null;
  document.getElementById('mdl-search-open').addEventListener('click', function(){
    searchOverlay.classList.add('open');
    setTimeout(() => searchInput.focus(), 300);
    swiper.mousewheel.disable();
  });
  document.getElementById('mdl-search-close').addEventListener('click', function(){
    searchOverlay.classList.remove('open');
    swiper.mousewheel.enable();
  });
  searchInput.addEventListener('input', function(e){
    clearTimeout(searchTimer);
    const q = e.target.value.trim();
    if(q.length < 2) { searchResults.innerHTML = ''; searchHint.textContent = 'Start typing to discover fragrances'; return; }
    searchHint.textContent = 'Searching...';
    searchTimer = setTimeout(() => {
      fetch(`/search/suggest.json?q=${encodeURIComponent(q)}&resources[type]=product&resources[limit]=6`)
        .then(r => r.json())
        .then(data => {
          const products = data.resources.results.products || [];
          if(products.length === 0) { searchHint.textContent = 'No fragrances found'; searchResults.innerHTML = ''; return; }
          searchHint.textContent = `${products.length} ${products.length === 1 ? 'result' : 'results'}`;
          searchResults.innerHTML = products.map(p => `
            <a href="${p.url}" class="mdl-search-result">
              ${p.image ? `<img src="${p.image}" class="mdl-search-result__img" alt="${p.title}">` : '<div class="mdl-search-result__img"></div>'}
              <div><div class="mdl-search-result__name">${p.title}</div><div class="mdl-search-result__price">${p.price}</div></div>
            </a>`).join('');
        });
    }, 250);
  });

  // CART
  const cartDrawer = document.getElementById('mdl-cart-drawer');
  const cartOverlay = document.getElementById('mdl-cart-overlay');
  const cartBody = document.getElementById('mdl-cart-body');
  const cartFoot = document.getElementById('mdl-cart-foot');
  const cartTotal = document.getElementById('mdl-cart-total');
  const cartCount = document.getElementById('mdl-cart-count');
  function fmt(c){ return '$' + (c/100).toFixed(2); }
  function fetchCart(){ fetch('/cart.js').then(r=>r.json()).then(renderCart); }
  function renderCart(cart){
    if(cartCount){ cartCount.textContent = cart.item_count; cartCount.style.display = cart.item_count > 0 ? 'flex' : 'none'; }
    if(cart.item_count === 0){
      cartBody.innerHTML = `<div class="mdl-cart-drawer__empty"><p>Your cart awaits.</p><a href="/collections/larbre-de-vie">Discover the Maison →</a></div>`;
      cartFoot.style.display = 'none'; return;
    }
    cartBody.innerHTML = cart.items.map(item => `
      <div class="mdl-cart-item" data-key="${item.key}">
        ${item.image ? `<img src="${item.image}" alt="${item.product_title}">` : '<div></div>'}
        <div class="mdl-cart-item__info">
          <div class="mdl-cart-item__name">${item.product_title}</div>
          <div class="mdl-cart-item__variant">${item.variant_title || ''}</div>
          ${item.properties && item.properties['Complimentary Sample'] ? `<div class="mdl-cart-item__sample">+ Free Sample: ${item.properties['Complimentary Sample']}</div>` : ''}
          <div class="mdl-cart-item__row">
            <div class="mdl-cart-item__qty">
              <button data-act="dec" data-key="${item.key}">−</button>
              <span>${item.quantity}</span>
              <button data-act="inc" data-key="${item.key}">+</button>
            </div>
            <div class="mdl-cart-item__price">${fmt(item.line_price)}</div>
          </div>
          <button class="mdl-cart-item__remove" data-act="rm" data-key="${item.key}">Remove</button>
        </div>
      </div>`).join('');
    cartTotal.textContent = fmt(cart.total_price);
    cartFoot.style.display = 'block';
    cartBody.querySelectorAll('button[data-act]').forEach(btn => {
      btn.addEventListener('click', function(){
        const key = this.getAttribute('data-key');
        const act = this.getAttribute('data-act');
        const item = cartBody.querySelector(`.mdl-cart-item[data-key="${key}"]`);
        const cur = parseInt(item.querySelector('.mdl-cart-item__qty span').textContent);
        let q = cur;
        if(act==='inc') q = cur+1; if(act==='dec') q = Math.max(0,cur-1); if(act==='rm') q = 0;
        fetch('/cart/change.js', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:key,quantity:q})}).then(r=>r.json()).then(renderCart);
      });
    });
  }
  function openCart(){ cartDrawer.classList.add('open'); cartOverlay.classList.add('open'); swiper.mousewheel.disable(); fetchCart(); }
  function closeCart(){ cartDrawer.classList.remove('open'); cartOverlay.classList.remove('open'); swiper.mousewheel.enable(); }
  document.getElementById('mdl-cart-open').addEventListener('click', openCart);
  document.getElementById('mdl-cart-close').addEventListener('click', closeCart);
  cartOverlay.addEventListener('click', closeCart);
  fetchCart();
  window.mdlOpenCart = openCart;
  window.mdlRefreshCart = fetchCart;
})();
</script>

