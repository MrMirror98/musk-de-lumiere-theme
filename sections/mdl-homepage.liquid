{{ 'homepage-mdl.css' | asset_url | stylesheet_tag }}

<!-- Swiper CSS from CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- assign larbre = collections['larbre-de-vie'] -%}
{%- assign essentials = collections['les-essentials'] -%}

<!-- ANNOUNCEMENT -->
<div class="mdl-announcement">
  Complimentary samples with every order &nbsp;·&nbsp;
  <a href="/collections">Discover L'Arbre de Vie →</a>
</div>

<!-- HEADER -->
<div class="mdl-header-wrapper" id="mdl-header">
  <div class="mdl-header">
    <nav><ul class="mdl-nav">
      <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
      <li><a href="/collections/les-essentials">Les Essentials</a></li>
      <li><a href="/collections">Collections</a></li>
      <li><a href="/pages/about">About</a></li>
    </ul></nav>
    <div class="mdl-logo-wrap">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}"
             alt="{{ shop.name }}" width="220" height="88" loading="eager">
      </a>
    </div>
    <div class="mdl-header-icons">
      <a href="{{ routes.search_url }}" class="mdl-header-icon" aria-label="Search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="mdl-header-icon" aria-label="Cart">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="mdl-cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <button class="mdl-hamburger" id="mdl-open" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</div>

<!-- MOBILE DRAWER -->
<div class="mdl-drawer" id="mdl-drawer">
  <button class="mdl-drawer__close" id="mdl-close" aria-label="Close">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <nav><ul>
    <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
    <li><a href="/collections/les-essentials">Les Essentials</a></li>
    <li><a href="/collections">Collections</a></li>
    <li><a href="/pages/about">About</a></li>
    <li><a href="/pages/contact">Contact</a></li>
  </ul></nav>
</div>

<!-- SLIDE COUNTER -->
<div class="mdl-slide-counter" id="mdl-counter">
  <span class="mdl-slide-counter__current" id="mdl-current">01</span>
  <span class="mdl-slide-counter__total">/ 06</span>
</div>

<!-- SWIPER CONTAINER -->
<div class="mdl-swiper-container">
  <div class="swiper mdl-swiper" id="mdl-swiper">
    <div class="swiper-wrapper">

      <!-- SLIDE 1: HERO -->
      <div class="swiper-slide mdl-slide-hero">
        <div class="mdl-slide-hero__bg">
          {%- if section.settings.hero_image != blank -%}
            <img src="{{ section.settings.hero_image | image_url: width: 2400 }}" alt="" loading="eager">
          {%- else -%}
            <div class="mdl-slide-hero__gradient"></div>
          {%- endif -%}
        </div>
        <div class="mdl-slide-hero__overlay"></div>
        <div class="mdl-slide-hero__content">
          <p class="mdl-eyebrow">Parfums d'Exception</p>
          <h1 class="mdl-hero-title">
            Where Light<br>Becomes <em>Scent</em>
          </h1>
          <p class="mdl-hero-sub">
            Twelve fragrances born from the marriage of French perfumery and ancient oud tradition.
          </p>
          <a href="/collections/larbre-de-vie" class="mdl-cta">
            Explore the Collection
            <span class="mdl-cta-line"></span>
          </a>
        </div>
      </div>

      <!-- SLIDE 2: L'ARBRE DE VIE -->
      <div class="swiper-slide">
        <a href="/collections/larbre-de-vie" class="mdl-slide-panel mdl-slide-panel--oud" style="display:flex;align-items:flex-end;width:100%;height:100%;text-decoration:none;">
          <div class="mdl-slide-panel__bg">
            {%- if section.settings.larbre_image != blank -%}
              <img src="{{ section.settings.larbre_image | image_url: width: 2000 }}" alt="" loading="lazy">
            {%- endif -%}
          </div>
          <div class="mdl-slide-panel__overlay"></div>
          <div class="mdl-slide-panel__num">01</div>
          <div class="mdl-slide-panel__content">
            <p class="mdl-slide-panel__label">Full Collection · 50ml</p>
            <h2 class="mdl-slide-panel__title">L'Arbre<br>de Vie</h2>
            <p class="mdl-slide-panel__desc">Eight fragrances. Oud, leather, rose, amber — the full architecture of a perfume house.</p>
            <span class="mdl-slide-panel__cta">Discover <span></span></span>
          </div>
        </a>
      </div>

      <!-- SLIDE 3: LES ESSENTIALS -->
      <div class="swiper-slide">
        <a href="/collections/les-essentials" class="mdl-slide-panel mdl-slide-panel--cream" style="display:flex;align-items:flex-end;width:100%;height:100%;text-decoration:none;">
          <div class="mdl-slide-panel__bg">
            {%- if section.settings.essentials_image != blank -%}
              <img src="{{ section.settings.essentials_image | image_url: width: 2000 }}" alt="" loading="lazy">
            {%- endif -%}
          </div>
          <div class="mdl-slide-panel__overlay"></div>
          <div class="mdl-slide-panel__num">02</div>
          <div class="mdl-slide-panel__content">
            <p class="mdl-slide-panel__label">Discovery Set · 10ml</p>
            <h2 class="mdl-slide-panel__title">Les<br>Essentials</h2>
            <p class="mdl-slide-panel__desc">Four signatures. The perfect way to begin your journey into Musk de Lumière.</p>
            <span class="mdl-slide-panel__cta">Discover <span></span></span>
          </div>
        </a>
      </div>

      <!-- SLIDE 4: PRODUCTS -->
      <div class="swiper-slide mdl-slide-products">
        <div class="mdl-products-head">
          <div class="mdl-products-head-left">
            <p class="mdl-eyebrow" style="color:#C9A84C;">The Collection</p>
            <h2 class="mdl-section-title">L'Arbre de Vie</h2>
          </div>
          <a href="/collections/larbre-de-vie" class="mdl-view-all">View All</a>
        </div>
        <div class="mdl-products-grid">
          {%- assign featured = larbre.products -%}
          {%- if featured.size == 0 -%}{%- assign featured = collections.all.products -%}{%- endif -%}
          {%- assign pnames = "Royale Oud,Chérie Oud,Sultanat Oud,Impériale Oud" | split: "," -%}
          {%- assign pnotes = "Leather · Oud · Smoke,Oud · Vanilla · Tonka,Powder · Amberwood · Oud,Rose · Velvet · Oud" | split: "," -%}
          {%- for product in featured limit: 4 -%}
            <a href="{{ product.url }}" class="mdl-card">
              <div class="mdl-card__img">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
                {%- else -%}
                  <div class="mdl-card__placeholder">{{ product.title }}</div>
                {%- endif -%}
              </div>
              <div class="mdl-card__info">
                <p class="mdl-card__tag">L'Arbre de Vie</p>
                <h3 class="mdl-card__name">{{ product.title }}</h3>
                <p class="mdl-card__price">{{ product.price | money }}</p>
              </div>
            </a>
          {%- else -%}
            {%- for i in (0..3) -%}
              <div class="mdl-card">
                <div class="mdl-card__img">
                  <div class="mdl-card__placeholder">{{ pnames[i] }}</div>
                </div>
                <div class="mdl-card__info">
                  <p class="mdl-card__tag">L'Arbre de Vie</p>
                  <h3 class="mdl-card__name">{{ pnames[i] }}</h3>
                  <p class="mdl-card__price">{{ pnotes[i] }}</p>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

      <!-- SLIDE 5: BRAND STORY -->
      <div class="swiper-slide mdl-slide-story">
        <div class="mdl-story-text">
          <p class="mdl-story-eyebrow">The House</p>
          <h2 class="mdl-story-title">Born from light.<br>Rooted in <em>tradition.</em></h2>
          <p class="mdl-story-body">Musk de Lumière is a fragrance house built on the belief that scent is the closest thing to memory. Drawing from French perfumery tradition and the ancient art of oud, each fragrance is an architecture — composed not worn.</p>
          <a href="/pages/about" class="mdl-story-link">Our Story <span></span></a>
        </div>
        <div class="mdl-story-img">
          {%- if section.settings.story_image != blank -%}
            <img src="{{ section.settings.story_image | image_url: width: 1000 }}" alt="" loading="lazy">
          {%- else -%}
            <div class="mdl-story-img-placeholder">Campaign Image</div>
          {%- endif -%}
        </div>
      </div>

      <!-- SLIDE 6: NEWSLETTER + FOOTER -->
      <div class="swiper-slide mdl-slide-last">
        <div class="mdl-newsletter">
          <p class="mdl-newsletter__eyebrow">The Inner Circle</p>
          <h2 class="mdl-newsletter__title">First Access. Always.</h2>
          <p class="mdl-newsletter__sub">New collections, exclusive releases, and the art behind the scent.</p>
          {%- form 'customer', id: 'mdl-newsletter' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="mdl-newsletter__form">
              <input class="mdl-newsletter__input" type="email" name="contact[email]"
                     placeholder="Your email address" required autocomplete="email">
              <button type="submit" class="mdl-newsletter__btn">Subscribe</button>
            </div>
          {%- endform -%}
        </div>
        <div class="mdl-footer">
          <div>
            <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}" alt="{{ shop.name }}" width="110" height="44">
            <p class="mdl-footer__tag">A fragrance house born from light and rooted in the art of perfumery.</p>
            <div class="mdl-footer__social">
              {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}">Instagram</a>{%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}<a href="{{ settings.social_tiktok_link }}">TikTok</a>{%- endif -%}
            </div>
          </div>
          <div class="mdl-footer__col"><h4>Collections</h4><ul>
            <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
            <li><a href="/collections/les-essentials">Les Essentials</a></li>
            <li><a href="/collections">All Fragrances</a></li>
          </ul></div>
          <div class="mdl-footer__col"><h4>The House</h4><ul>
            <li><a href="/pages/about">Our Story</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          </ul></div>
          <div class="mdl-footer__col"><h4>Information</h4><ul>
            <li><a href="/policies/shipping-policy">Shipping</a></li>
            <li><a href="/policies/refund-policy">Returns</a></li>
            <li><a href="/policies/privacy-policy">Privacy</a></li>
          </ul></div>
        </div>
        <div class="mdl-footer__bottom">
          <span class="mdl-footer__copy">© {{ 'now' | date: '%Y' }} Musk de Lumière. All rights reserved.</span>
          <span class="mdl-footer__copy">Parsippany, NJ · muskdelumiere.com</span>
        </div>
      </div>

    </div><!-- end swiper-wrapper -->

    <!-- RIGHT SIDE PAGINATION -->
    <div class="swiper-pagination"></div>

  </div><!-- end swiper -->
</div><!-- end container -->

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
(function(){
  // Init Swiper
  const swiper = new Swiper('#mdl-swiper', {
    direction: 'vertical',
    slidesPerView: 1,
    speed: 900,
    mousewheel: {
      sensitivity: 1,
      thresholdDelta: 50
    },
    keyboard: { enabled: true },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
      dynamicBullets: false
    },
    on: {
      slideChange: function() {
        const n = String(this.activeIndex + 1).padStart(2, '0');
        const counter = document.getElementById('mdl-current');
        if(counter) counter.textContent = n;
        // Header solid after first slide
        const header = document.getElementById('mdl-header');
        if(this.activeIndex > 0) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      }
    }
  });

  // Mobile drawer
  document.getElementById('mdl-open').addEventListener('click', function(){
    document.getElementById('mdl-drawer').classList.add('open');
    document.body.style.overflow = 'hidden';
    swiper.mousewheel.disable();
  });
  function closeDrawer(){
    document.getElementById('mdl-drawer').classList.remove('open');
    document.body.style.overflow = '';
    swiper.mousewheel.enable();
  }
  document.getElementById('mdl-close').addEventListener('click', closeDrawer);
  document.querySelectorAll('.mdl-drawer a').forEach(function(a){
    a.addEventListener('click', closeDrawer);
  });
})();
</script>

{% schema %}
{
  "name": "MDL Homepage",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero background image" },
    { "type": "image_picker", "id": "larbre_image", "label": "L'Arbre de Vie image" },
    { "type": "image_picker", "id": "essentials_image", "label": "Les Essentials image" },
    { "type": "image_picker", "id": "story_image", "label": "Brand story image" }
  ],
  "presets": [{ "name": "MDL Homepage" }]
}
{% endschema %}
