{{ 'homepage-mdl.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<style>
html, body { overflow: auto !important; height: auto !important; position: static !important; }

/* ============================================
   COLLECTION PAGE — Editorial luxury layout
============================================ */
.mdl-coll { background: #FFFFFF; color: #0A0A0A; min-height: 100vh; padding-top: 160px; }

/* ===== HERO ===== */
.mdl-coll__hero { padding: 0 96px 64px; max-width: 700px; }
.mdl-coll__eyebrow {
  font-family: 'Montserrat', sans-serif;
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.4em; text-transform: uppercase;
  color: #C9A84C; margin-bottom: 20px;
}
.mdl-coll__title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(42px, 5vw, 72px);
  font-weight: 300; line-height: 0.95;
  letter-spacing: -0.02em; color: #0A0A0A;
  margin-bottom: 20px;
}
.mdl-coll__desc {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; font-style: italic; font-weight: 300;
  line-height: 1.8; color: rgba(10,10,10,0.5);
  max-width: 480px;
}

/* ===== SECTION HEADERS ===== */
.mdl-coll__section-head {
  padding: 60px 96px 36px;
  display: flex; align-items: baseline; gap: 20px;
}
.mdl-coll__section-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 9px; font-weight: 600;
  letter-spacing: 0.4em; text-transform: uppercase;
  color: #C9A84C;
}
.mdl-coll__section-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px; font-style: italic; font-weight: 300;
  color: rgba(10,10,10,0.4);
}

/* ===== PRODUCT GRID — 4 columns, clean luxury cards ===== */
.mdl-coll__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  padding: 0 96px;
  background: rgba(10,10,10,0.04);
}
.mdl-coll__card {
  background: #FFFFFF;
  display: flex; flex-direction: column;
  text-decoration: none; color: inherit;
  overflow: hidden;
  transition: background 0.4s;
}
.mdl-coll__card:hover { background: #FAFAF7; }

.mdl-coll__card-img {
  aspect-ratio: 3/4;
  overflow: hidden;
  background: linear-gradient(160deg, #F5F0E8, #EBE3D5);
}
.mdl-coll__card-img img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.9s cubic-bezier(0.19,1,0.22,1);
}
.mdl-coll__card:hover .mdl-coll__card-img img { transform: scale(1.05); }

.mdl-coll__card-placeholder {
  width: 100%; height: 100%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 12px;
}
.mdl-coll__card-placeholder em {
  font-style: normal; font-size: 8px; font-weight: 600;
  letter-spacing: 0.38em; text-transform: uppercase;
  color: rgba(10,10,10,0.18);
}
.mdl-coll__card-placeholder strong {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 400; font-style: italic;
  color: rgba(10,10,10,0.3);
}

.mdl-coll__card-info { padding: 20px 16px 28px; text-align: center; }
.mdl-coll__card-tag {
  font-family: 'Montserrat', sans-serif;
  font-size: 7px; font-weight: 600;
  letter-spacing: 0.32em; text-transform: uppercase;
  color: #C9A84C; margin-bottom: 8px;
}
.mdl-coll__card-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 300;
  color: #0A0A0A; margin-bottom: 6px;
}
.mdl-coll__card-notes {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px; font-style: italic; font-weight: 300;
  color: rgba(10,10,10,0.4);
  line-height: 1.5; margin-bottom: 10px;
}
.mdl-coll__card-price {
  font-family: 'Montserrat', sans-serif;
  font-size: 11px; font-weight: 400;
  letter-spacing: 0.08em; color: rgba(10,10,10,0.6);
}

/* ===== DISCOVERY SET INTERSTITIAL — scroll-zoom with popup ===== */
.mdl-coll__discovery {
  position: relative;
  height: 100vh;
  overflow: hidden;
  margin: 80px 0;
  background: #0A0A0A;
}
.mdl-coll__discovery-img {
  position: absolute; inset: -10%;
  will-change: transform;
  transition: transform 0.1s linear;
}
.mdl-coll__discovery-img img {
  width: 100%; height: 100%; object-fit: cover;
  opacity: 0.7;
}
.mdl-coll__discovery-img-placeholder {
  width: 100%; height: 100%;
  background:
    radial-gradient(ellipse at 40% 40%, rgba(201,168,76,0.12) 0%, transparent 55%),
    linear-gradient(160deg, #151210, #0A0A0A);
  display: flex; align-items: center; justify-content: center;
}
.mdl-coll__discovery-img-placeholder span {
  font-family: 'Cormorant Garamond', serif;
  font-size: 80px; font-weight: 300; font-style: italic;
  color: rgba(201,168,76,0.08);
}
.mdl-coll__discovery-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(10,10,10,0.5) 0%, rgba(10,10,10,0.3) 50%, rgba(10,10,10,0.6) 100%);
  z-index: 1;
}

/* Title top-left */
.mdl-coll__discovery-text {
  position: absolute;
  top: 180px; left: 96px;
  z-index: 2; max-width: 500px;
}
.mdl-coll__discovery-chapter {
  font-family: 'Cormorant Garamond', serif;
  font-size: 13px; font-style: italic;
  color: #C9A84C; letter-spacing: 0.12em;
  margin-bottom: 14px;
}
.mdl-coll__discovery-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 5vw, 72px);
  font-weight: 300; line-height: 0.92;
  color: #F5F0E8; margin-bottom: 18px;
}
.mdl-coll__discovery-title em { font-style: italic; color: #C9A84C; }
.mdl-coll__discovery-lead {
  font-size: 12px; font-weight: 300;
  line-height: 2; letter-spacing: 0.07em;
  color: rgba(245,240,232,0.6);
  max-width: 400px;
}

/* Popup card — bottom right, Byredo-style */
.mdl-coll__discovery-popup {
  position: absolute;
  bottom: 80px; right: 96px;
  z-index: 3;
  display: flex;
  background: rgba(245,240,232,0.55);
  backdrop-filter: blur(20px) saturate(130%);
  -webkit-backdrop-filter: blur(20px) saturate(130%);
  border-left: 2px solid #C9A84C;
  min-height: 120px;
  max-width: 440px;
  text-decoration: none; color: inherit;
  transition: background 0.3s;
}
.mdl-coll__discovery-popup:hover {
  background: rgba(245,240,232,0.7);
}
.mdl-coll__popup-img {
  flex: 0 0 120px;
  background: linear-gradient(160deg, #1A150E, #0D0B08);
  overflow: hidden;
}
.mdl-coll__popup-img img { width: 100%; height: 100%; object-fit: cover; }
.mdl-coll__popup-img-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px; font-style: italic;
  color: rgba(201,168,76,0.5);
}
.mdl-coll__popup-content { padding: 18px 24px; flex: 1; position: relative; }
.mdl-coll__popup-tag {
  font-family: 'Montserrat', sans-serif;
  font-size: 7px; font-weight: 600;
  letter-spacing: 0.35em; text-transform: uppercase;
  color: #C9A84C; margin-bottom: 6px;
}
.mdl-coll__popup-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 400;
  color: #0A0A0A; margin-bottom: 4px;
}
.mdl-coll__popup-sub {
  font-family: 'Montserrat', sans-serif;
  font-size: 9px; font-weight: 400;
  letter-spacing: 0.08em; color: rgba(10,10,10,0.5);
  margin-bottom: 12px;
}
.mdl-coll__popup-bottom {
  display: flex; justify-content: space-between; align-items: center;
}
.mdl-coll__popup-price {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-weight: 300; color: #0A0A0A;
}
.mdl-coll__popup-cta {
  font-family: 'Montserrat', sans-serif;
  font-size: 7px; font-weight: 700;
  letter-spacing: 0.3em; text-transform: uppercase;
  color: #0A0A0A;
  display: flex; align-items: center; gap: 8px;
}
.mdl-coll__popup-cta span {
  display: block; width: 24px; height: 1px;
  background: #C9A84C;
}

/* ===== CROSS-SELL FOOTER ===== */
.mdl-coll__cross {
  padding: 80px 96px;
  text-align: center;
  background: #FFFFFF;
}
.mdl-coll__cross-link {
  font-family: 'Montserrat', sans-serif;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.35em; text-transform: uppercase;
  color: #0A0A0A; text-decoration: underline;
  text-underline-offset: 4px;
}
.mdl-coll__cross-link:hover { color: #C9A84C; }

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .mdl-coll { padding-top: 130px; }
  .mdl-coll__hero { padding: 0 24px 48px; }
  .mdl-coll__section-head { padding: 40px 24px 24px; }
  .mdl-coll__grid { grid-template-columns: 1fr 1fr; padding: 0 24px; }
  .mdl-coll__card-name { font-size: 18px; }
  .mdl-coll__card-notes { font-size: 10px; }
  .mdl-coll__discovery-text { top: 140px; left: 24px; right: 24px; }
  .mdl-coll__discovery-popup {
    bottom: 60px; right: 24px; left: 24px;
    max-width: none;
  }
  .mdl-coll__cross { padding: 60px 24px; }
}
@media (max-width: 600px) {
  .mdl-coll__grid { grid-template-columns: 1fr 1fr; gap: 1px; padding: 0 16px; }
  .mdl-coll__card-info { padding: 14px 10px 20px; }
  .mdl-coll__card-name { font-size: 16px; }
  .mdl-coll__discovery-title { font-size: 36px; }
  .mdl-coll__discovery-popup { flex-direction: column; }
  .mdl-coll__popup-img { flex: 0 0 160px; }
}
</style>

{%- comment -%}
  Separate products into Light, Roots, and Discovery
{%- endcomment -%}

{%- assign light_products = "" | split: "" -%}
{%- assign root_products = "" | split: "" -%}
{%- assign discovery_product = nil -%}
{%- assign other_products = "" | split: "" -%}

{%- for product in collection.products -%}
  {%- if product.tags contains "Discovery Set" -%}
    {%- assign discovery_product = product -%}
  {%- elsif product.tags contains "Les Branches" -%}
    {%- assign light_products = light_products | concat: product | default: light_products -%}
  {%- elsif product.tags contains "Les Racines" -%}
    {%- assign root_products = root_products | concat: product | default: root_products -%}
  {%- else -%}
    {%- assign other_products = other_products | concat: product | default: other_products -%}
  {%- endif -%}
{%- endfor -%}

<div class="mdl-coll">
  <!-- HERO -->
  <header class="mdl-coll__hero">
    <p class="mdl-coll__eyebrow">Musk de Lumière</p>
    <h1 class="mdl-coll__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="mdl-coll__desc">{{ collection.description }}</p>
    {%- endif -%}
  </header>

  {%- if collection.handle == 'larbre-de-vie' -%}

    <!-- ============ THE LIGHT — 4 bottles ============ -->
    <div class="mdl-coll__section-head">
      <span class="mdl-coll__section-label">Les Branches</span>
      <span class="mdl-coll__section-sub">The Light</span>
    </div>
    <div class="mdl-coll__grid">
      {%- for product in collection.products -%}
        {%- if product.tags contains "Les Branches" -%}
          <a href="{{ product.url }}" class="mdl-coll__card">
            <div class="mdl-coll__card-img">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy">
              {%- else -%}
                <div class="mdl-coll__card-placeholder">
                  <em>Les Branches</em>
                  <strong>{{ product.title }}</strong>
                </div>
              {%- endif -%}
            </div>
            <div class="mdl-coll__card-info">
              <p class="mdl-coll__card-tag">Les Branches</p>
              <h2 class="mdl-coll__card-name">{{ product.title }}</h2>
              {%- if product.metafields.custom.notes_summary != blank -%}
                <p class="mdl-coll__card-notes">{{ product.metafields.custom.notes_summary }}</p>
              {%- endif -%}
              <p class="mdl-coll__card-price">{{ product.price | money }}</p>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- ============ DISCOVERY SET INTERSTITIAL ============ -->
    {%- assign ds = all_products['discovery-set-larbre-de-vie'] -%}
    <div class="mdl-coll__discovery" id="mdl-discovery-scroll">
      <div class="mdl-coll__discovery-img" id="mdl-discovery-img">
        {%- if ds != blank and ds.featured_image -%}
          <img src="{{ ds.featured_image | image_url: width: 2400 }}" alt="L'Arbre de Vie Discovery Set">
        {%- elsif section.settings.discovery_image != blank -%}
          <img src="{{ section.settings.discovery_image | image_url: width: 2400 }}" alt="Discovery Set">
        {%- else -%}
          <div class="mdl-coll__discovery-img-placeholder"><span>L'Arbre de Vie</span></div>
        {%- endif -%}
      </div>
      <div class="mdl-coll__discovery-overlay"></div>

      <div class="mdl-coll__discovery-text">
        <p class="mdl-coll__discovery-chapter">Le Coffret</p>
        <h2 class="mdl-coll__discovery-title">The <em>Discovery</em>.</h2>
        <p class="mdl-coll__discovery-lead">Eight signatures in miniature. The full architecture of the tree — from the smoke of the Roots to the light of the Branches — sized for discovery.</p>
      </div>

      <a href="{% if ds != blank and ds.id %}{{ ds.url }}{% else %}/collections/larbre-de-vie{% endif %}" class="mdl-coll__discovery-popup">
        <div class="mdl-coll__popup-img">
          {%- if ds != blank and ds.featured_image -%}
            <img src="{{ ds.featured_image | image_url: width: 400 }}" alt="">
          {%- else -%}
            <div class="mdl-coll__popup-img-ph">Coffret</div>
          {%- endif -%}
        </div>
        <div class="mdl-coll__popup-content">
          <p class="mdl-coll__popup-tag">L'Arbre de Vie</p>
          <h3 class="mdl-coll__popup-name">Discovery Set</h3>
          <p class="mdl-coll__popup-sub">8 × 2.5 ml travel sprays</p>
          <div class="mdl-coll__popup-bottom">
            <span class="mdl-coll__popup-cta">Discover the Set <span></span></span>
          </div>
        </div>
      </a>
    </div>

    <!-- ============ THE ROOTS — 4 ouds ============ -->
    <div class="mdl-coll__section-head">
      <span class="mdl-coll__section-label">Les Racines</span>
      <span class="mdl-coll__section-sub">The Roots</span>
    </div>
    <div class="mdl-coll__grid">
      {%- for product in collection.products -%}
        {%- if product.tags contains "Les Racines" -%}
          <a href="{{ product.url }}" class="mdl-coll__card">
            <div class="mdl-coll__card-img">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy">
              {%- else -%}
                <div class="mdl-coll__card-placeholder">
                  <em>Les Racines</em>
                  <strong>{{ product.title }}</strong>
                </div>
              {%- endif -%}
            </div>
            <div class="mdl-coll__card-info">
              <p class="mdl-coll__card-tag">Les Racines</p>
              <h2 class="mdl-coll__card-name">{{ product.title }}</h2>
              {%- if product.metafields.custom.notes_summary != blank -%}
                <p class="mdl-coll__card-notes">{{ product.metafields.custom.notes_summary }}</p>
              {%- endif -%}
              <p class="mdl-coll__card-price">{{ product.price | money }}</p>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

  {%- else -%}

    <!-- ============ GENERIC COLLECTION (Les Essentials, etc) ============ -->
    <div class="mdl-coll__grid">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" class="mdl-coll__card">
          <div class="mdl-coll__card-img">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy">
            {%- else -%}
              <div class="mdl-coll__card-placeholder">
                <em>{{ collection.title }}</em>
                <strong>{{ product.title }}</strong>
              </div>
            {%- endif -%}
          </div>
          <div class="mdl-coll__card-info">
            <p class="mdl-coll__card-tag">{{ collection.title }}</p>
            <h2 class="mdl-coll__card-name">{{ product.title }}</h2>
            {%- if product.metafields.custom.notes_summary != blank -%}
              <p class="mdl-coll__card-notes">{{ product.metafields.custom.notes_summary }}</p>
            {%- endif -%}
            <p class="mdl-coll__card-price">{{ product.price | money }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>

  {%- endif -%}

  <!-- CROSS-SELL -->
  <div class="mdl-coll__cross">
    {%- if collection.handle == 'larbre-de-vie' -%}
      <a href="/collections/les-essentials" class="mdl-coll__cross-link">Explore Les Essentials →</a>
    {%- elsif collection.handle == 'les-essentials' -%}
      <a href="/collections/larbre-de-vie" class="mdl-coll__cross-link">Explore L'Arbre de Vie →</a>
    {%- endif -%}
  </div>
</div>

<!-- Scroll-zoom effect on Discovery Set image -->
<script>
(function(){
  const section = document.getElementById('mdl-discovery-scroll');
  const img = document.getElementById('mdl-discovery-img');
  if(!section || !img) return;

  function onScroll(){
    const rect = section.getBoundingClientRect();
    const vh = window.innerHeight;
    // Only animate when section is in viewport
    if(rect.bottom < 0 || rect.top > vh) return;
    // Progress: 0 when section enters bottom, 1 when it exits top
    const progress = 1 - (rect.bottom / (vh + rect.height));
    // Scale from 1.0 to 1.15 as user scrolls through
    const scale = 1 + (progress * 0.15);
    img.style.transform = 'scale(' + Math.min(scale, 1.15) + ')';
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>

{% schema %}
{
  "name": "MDL Collection",
  "settings": [
    { "type": "image_picker", "id": "discovery_image", "label": "Discovery Set background image (fallback)" }
  ]
}
{% endschema %}
