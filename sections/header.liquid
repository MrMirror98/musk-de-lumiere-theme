<link rel="stylesheet" href="{{ 'header-mdl.css' | asset_url }}" media="all">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

<!-- Announcement Bar -->
<div class="mdl-announcement" role="region" aria-label="Announcement">
  <span>Complimentary samples with every order &nbsp;·&nbsp; <a href="/collections">Discover L'Arbre de Vie</a></span>
</div>

<!-- Header -->
<div class="mdl-header-wrapper is-transparent" id="mdl-header" role="banner">
  <div class="mdl-header">

    <!-- Left: Desktop Nav -->
    <nav aria-label="Main navigation">
      <ul class="mdl-nav">
        <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
        <li><a href="/collections/les-essentials">Les Essentials</a></li>
        <li><a href="/collections">Collections</a></li>
        <li><a href="/pages/about">About</a></li>
      </ul>
    </nav>

    <!-- Center: Logo -->
    <div class="mdl-logo-wrap">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: 300 | image_tag:
            class: 'mdl-logo-img',
            alt: shop.name,
            width: 150,
            height: 60
          }}
        {%- else -%}
          <img
            src="{{ 'logo-musk-de-lumiere.png' | asset_url }}"
            alt="{{ shop.name }}"
            width="150"
            height="60"
            loading="eager"
            fetchpriority="high"
          >
        {%- endif -%}
      </a>
    </div>

    <!-- Right: Icons + Mobile Hamburger -->
    <div class="mdl-header-icons">

      <!-- Search -->
      <button class="mdl-header-icon mdl-header-icon--search" aria-label="Search" onclick="window.location='/search'">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
      </button>

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="mdl-header-icon mdl-header-icon--cart" aria-label="Cart ({{ cart.item_count }} items)">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="mdl-cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <!-- Mobile Hamburger -->
      <button class="mdl-hamburger" aria-label="Open menu" id="mdl-hamburger">
        <span></span>
        <span></span>
        <span></span>
      </button>

    </div>
  </div>
</div>

<!-- Mobile Drawer -->
<div class="mdl-mobile-drawer" id="mdl-mobile-drawer" aria-hidden="true" role="dialog" aria-label="Navigation menu">

  <div class="mdl-mobile-drawer-logo">
    <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}" alt="{{ shop.name }}" width="120" height="48" loading="lazy">
  </div>

  <button class="mdl-mobile-drawer-close" aria-label="Close menu" id="mdl-drawer-close">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <nav aria-label="Mobile navigation">
    <ul class="mdl-mobile-nav">
      <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
      <li><a href="/collections/les-essentials">Les Essentials</a></li>
      <li><a href="/collections">Collections</a></li>
      <li><a href="/pages/about">About</a></li>
      <li><a href="/pages/contact">Contact</a></li>
    </ul>
  </nav>
</div>

<script>
  // Header scroll behavior
  (function() {
    const header = document.getElementById('mdl-header');
    const announcementBar = document.querySelector('.mdl-announcement');
    let lastScroll = 0;

    function updateHeader() {
      const scrollY = window.scrollY;
      const announcementHeight = announcementBar ? announcementBar.offsetHeight : 0;

      if (scrollY > announcementHeight + 10) {
        header.classList.remove('is-transparent');
        header.classList.add('is-solid');
      } else {
        header.classList.remove('is-solid');
        header.classList.add('is-transparent');
      }
      lastScroll = scrollY;
    }

    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();

    // Mobile drawer
    const hamburger = document.getElementById('mdl-hamburger');
    const drawer = document.getElementById('mdl-mobile-drawer');
    const drawerClose = document.getElementById('mdl-drawer-close');

    hamburger.addEventListener('click', function() {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    });

    function closeDrawer() {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    drawerClose.addEventListener('click', closeDrawer);

    // Close on nav link click
    drawer.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', closeDrawer);
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation menu"
    }
  ]
}
{% endschema %}
