{{ 'product-mdl.css' | asset_url | stylesheet_tag }}

{%- assign mf = product.metafields.custom -%}
{%- assign is_larbre = false -%}
{%- if product.tags contains "L'Arbre de Vie" -%}{%- assign is_larbre = true -%}{%- endif -%}

<article class="mdl-pdp" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="{{ product.title }}">
  <meta itemprop="brand" content="Musk de Lumière">
  <meta itemprop="sku" content="{{ product.selected_or_first_available_variant.sku }}">

  <!-- ============== GALLERY (left, scrolls with page) ============== -->
  <div class="mdl-pdp__gallery">
    {%- if product.images.size > 0 -%}
      {%- for image in product.images -%}
        <div class="mdl-pdp__img-wrap">
          <img src="{{ image | image_url: width: 1400 }}"
               alt="{{ product.title }} by Musk de Lumière — {{ mf.fragrance_family | default: 'Eau de Parfum' }}"
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
               itemprop="image">
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="mdl-pdp__img-wrap">
        <div class="mdl-pdp__placeholder">
          <em>{{ mf.fragrance_family | default: product.collections.first.title | default: 'Musk de Lumière' }}</em>
          <strong>{{ product.title }}</strong>
        </div>
      </div>
    {%- endif -%}
  </div>

  <!-- ============== INFO SIDEBAR (right, sticky) ============== -->
  <aside class="mdl-pdp__info">
    <div class="mdl-pdp__info-inner">

      <p class="mdl-pdp__collection">
        {%- if is_larbre -%}L'Arbre de Vie{%- elsif product.tags contains "Les Essentials" -%}Les Essentials{%- else -%}{{ product.collections.first.title | default: "Musk de Lumière" }}{%- endif -%}
      </p>
      <h1 class="mdl-pdp__name" itemprop="name">{{ product.title }}</h1>
      <p class="mdl-pdp__type">{{ mf.concentration | default: 'Eau de Parfum' }} · {{ product.selected_or_first_available_variant.title }}</p>

      {%- if mf.notes_summary != blank -%}
        <p class="mdl-pdp__notes">{{ mf.notes_summary }}</p>
      {%- endif -%}

      <p class="mdl-pdp__price" id="mdl-pdp-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
        <meta itemprop="price" content="{{ product.selected_or_first_available_variant.price | divided_by: 100.00 }}">
        <meta itemprop="availability" content="{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}">
        {{ product.selected_or_first_available_variant.price | money }}
      </p>

      {%- if mf.olfactive_description != blank -%}
        <p class="mdl-pdp__olfactive">{{ mf.olfactive_description }}</p>
      {%- endif -%}

      <form id="mdl-pdp-form" data-product-id="{{ product.id }}">
        {%- if product.variants.size > 1 -%}
          <div class="mdl-pdp__variants">
            <p class="mdl-pdp__variants-label">Size</p>
            <div class="mdl-pdp__variants-grid">
              {%- for variant in product.variants -%}
                <button type="button" class="mdl-pdp__variant {% if variant.id == product.selected_or_first_available_variant.id %}active{% endif %}"
                        data-id="{{ variant.id }}"
                        data-price-formatted="{{ variant.price | money }}">
                  {{ variant.title }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <input type="hidden" name="id" id="mdl-pdp-variant" value="{{ product.selected_or_first_available_variant.id }}">

        <!-- COMPLIMENTARY SAMPLE SELECTOR — only L'Arbre de Vie 2.5ml available -->
        <div class="mdl-pdp__sample">
          <div class="mdl-pdp__sample-head">
            <span class="mdl-pdp__sample-label">Complimentary Sample</span>
            <span class="mdl-pdp__sample-tag">Free with every order</span>
          </div>
          <div class="mdl-pdp__select-wrap">
            <select name="properties[Complimentary Sample]" id="mdl-pdp-sample" class="mdl-pdp__select">
              <option value="Surprise me — Maison's choice">Surprise me — Maison's choice</option>
              <option value="Royale Oud — 2.5ml" {% if product.handle == 'royale-oud' %}disabled{% endif %}>Royale Oud — 2.5ml</option>
              <option value="Chérie Oud — 2.5ml" {% if product.handle == 'cherie-oud' %}disabled{% endif %}>Chérie Oud — 2.5ml</option>
              <option value="Sultanat Oud — 2.5ml" {% if product.handle == 'sultanat-oud' %}disabled{% endif %}>Sultanat Oud — 2.5ml</option>
              <option value="Impériale Oud — 2.5ml" {% if product.handle == 'imperiale-oud' %}disabled{% endif %}>Impériale Oud — 2.5ml</option>
              <option value="Paradis de Bleu — 2.5ml" {% if product.handle == 'paradis-de-bleu' %}disabled{% endif %}>Paradis de Bleu — 2.5ml</option>
              <option value="Néroli de Nuit — 2.5ml" {% if product.handle == 'neroli-de-nuit' %}disabled{% endif %}>Néroli de Nuit — 2.5ml</option>
              <option value="Hayal — 2.5ml" {% if product.handle == 'hayal' %}disabled{% endif %}>Hayal — 2.5ml</option>
              <option value="Rosée Blanche — 2.5ml" {% if product.handle == 'rosee-blanche' %}disabled{% endif %}>Rosée Blanche — 2.5ml</option>
            </select>
            <svg class="mdl-pdp__select-chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
          </div>
          <p class="mdl-pdp__sample-note">Samples currently available only from the L'Arbre de Vie collection. Les Essentials samples coming soon.</p>
        </div>

        <button type="submit" class="mdl-pdp__add" id="mdl-pdp-add">
          <span>Add to Cart</span>
        </button>
      </form>

      <!-- SCENT PYRAMID -->
      {%- if mf.scent_top != blank or mf.scent_heart != blank or mf.scent_base != blank -%}
        <div class="mdl-pdp__pyramid">
          <h3 class="mdl-pdp__pyramid-title">The Composition</h3>
          {%- if mf.scent_top != blank and mf.scent_top != "—" -%}
            <div class="mdl-pdp__pyramid-row">
              <span class="mdl-pdp__pyramid-label">Top</span>
              <span class="mdl-pdp__pyramid-notes">{{ mf.scent_top }}</span>
            </div>
          {%- endif -%}
          {%- if mf.scent_heart != blank and mf.scent_heart != "—" -%}
            <div class="mdl-pdp__pyramid-row">
              <span class="mdl-pdp__pyramid-label">Heart</span>
              <span class="mdl-pdp__pyramid-notes">{{ mf.scent_heart }}</span>
            </div>
          {%- endif -%}
          {%- if mf.scent_base != blank and mf.scent_base != "—" -%}
            <div class="mdl-pdp__pyramid-row">
              <span class="mdl-pdp__pyramid-label">Base</span>
              <span class="mdl-pdp__pyramid-notes">{{ mf.scent_base }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <!-- WEAR ATTRIBUTES (longevity / sillage / season / occasion) -->
      {%- if mf.longevity != blank or mf.sillage != blank or mf.best_season != blank -%}
        <div class="mdl-pdp__attrs">
          {%- if mf.longevity != blank -%}
            <div class="mdl-pdp__attr"><dt>Longevity</dt><dd>{{ mf.longevity }}</dd></div>
          {%- endif -%}
          {%- if mf.sillage != blank -%}
            <div class="mdl-pdp__attr"><dt>Sillage</dt><dd>{{ mf.sillage }}</dd></div>
          {%- endif -%}
          {%- if mf.best_season != blank -%}
            <div class="mdl-pdp__attr"><dt>Best Season</dt><dd>{{ mf.best_season }}</dd></div>
          {%- endif -%}
          {%- if mf.best_occasion != blank -%}
            <div class="mdl-pdp__attr"><dt>Wear For</dt><dd>{{ mf.best_occasion }}</dd></div>
          {%- endif -%}
          {%- if mf.gender != blank -%}
            <div class="mdl-pdp__attr"><dt>Made For</dt><dd>{{ mf.gender | capitalize }}</dd></div>
          {%- endif -%}
          {%- if mf.fragrance_family != blank -%}
            <div class="mdl-pdp__attr"><dt>Family</dt><dd>{{ mf.fragrance_family }}</dd></div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <!-- EXPANDABLE STORY SECTIONS -->
      <div class="mdl-pdp__details">
        {%- if mf.inspiration != blank -%}
          <details class="mdl-pdp__detail" open>
            <summary>The Inspiration</summary>
            <p>{{ mf.inspiration }}</p>
          </details>
        {%- endif -%}
        {%- if mf.about_the_name != blank -%}
          <details class="mdl-pdp__detail">
            <summary>About the Name</summary>
            <p>{{ mf.about_the_name }}</p>
          </details>
        {%- endif -%}
        {%- if mf.perfumer_signature != blank -%}
          <details class="mdl-pdp__detail">
            <summary>Note from the Perfumer</summary>
            <p>{{ mf.perfumer_signature }}</p>
          </details>
        {%- endif -%}
        {%- if mf.bottle_description != blank -%}
          <details class="mdl-pdp__detail">
            <summary>The Bottle</summary>
            <p>{{ mf.bottle_description }}</p>
          </details>
        {%- endif -%}
        {%- if mf.ingredients_inci != blank -%}
          <details class="mdl-pdp__detail">
            <summary>Ingredients (INCI)</summary>
            <p>{{ mf.ingredients_inci }}</p>
          </details>
        {%- endif -%}
        {%- if mf.pairs_well_with != blank -%}
          <details class="mdl-pdp__detail">
            <summary>Pairs Well With</summary>
            <p>{{ mf.pairs_well_with }}</p>
          </details>
        {%- endif -%}
        <details class="mdl-pdp__detail">
          <summary>Shipping &amp; Returns</summary>
          <p>Complimentary domestic shipping on all orders over $100. 30-day returns on unopened items. Discrete packaging with signature Musk de Lumière wrapping.</p>
        </details>
      </div>
    </div>
  </aside>
</article>


<!-- ============== BYREDO-STYLE SCENT NOTES — FULL SCREEN ============== -->
{%- if mf.scent_top != blank and mf.scent_top != "—" -%}
<section class="mdl-notes" id="product-notes">
  <div class="mdl-notes__bg"
       style="background-image: linear-gradient(0deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.4) 100%),
              url('{% if product.images.size > 1 %}{{ product.images[1] | image_url: width: 2400 }}{% elsif product.featured_image %}{{ product.featured_image | image_url: width: 2400 }}{% endif %}');">
    <div class="swiper mdl-notes__swiper" id="mdl-notes-swiper">
      <div class="swiper-wrapper">
        {%- if mf.scent_top != blank and mf.scent_top != "—" -%}
        <div class="swiper-slide">
          <div class="mdl-notes__slide">
            <div class="mdl-notes__label">Top Notes</div>
            <ul class="mdl-notes__list">
              {%- assign tops = mf.scent_top | split: ", " -%}
              {%- for note in tops -%}
                <li>{{ note }}</li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
        {%- endif -%}
        {%- if mf.scent_heart != blank and mf.scent_heart != "—" -%}
        <div class="swiper-slide">
          <div class="mdl-notes__slide">
            <div class="mdl-notes__label">Heart Notes</div>
            <ul class="mdl-notes__list">
              {%- assign hearts = mf.scent_heart | split: ", " -%}
              {%- for note in hearts -%}
                <li>{{ note }}</li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
        {%- endif -%}
        {%- if mf.scent_base != blank and mf.scent_base != "—" -%}
        <div class="swiper-slide">
          <div class="mdl-notes__slide">
            <div class="mdl-notes__label">Base Notes</div>
            <ul class="mdl-notes__list">
              {%- assign bases = mf.scent_base | split: ", " -%}
              {%- for note in bases -%}
                <li>{{ note }}</li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
        {%- endif -%}
      </div>
      <div class="swiper-scrollbar mdl-notes__scrollbar"></div>
    </div>
  </div>
</section>

<!-- ============== CAMPAIGN / STORY BLOCK ============== -->
<section class="mdl-campaign">
  <div class="mdl-campaign__grid">
    {%- if product.images.size > 2 -%}
    <div class="mdl-campaign__img mdl-campaign__img--full">
      <img src="{{ product.images[2] | image_url: width: 2400 }}" alt="{{ product.title }} campaign" loading="lazy">
    </div>
    {%- endif -%}
    <div class="mdl-campaign__text">
      {%- if mf.inspiration != blank -%}
        <h2 class="mdl-campaign__title">The Inspiration</h2>
        <p class="mdl-campaign__body">{{ mf.inspiration }}</p>
      {%- elsif mf.olfactive_description != blank -%}
        <h2 class="mdl-campaign__title">The Story</h2>
        <p class="mdl-campaign__body">{{ mf.olfactive_description }}</p>
      {%- endif -%}
      <a href="/collections/{% if is_larbre %}larbre-de-vie{% else %}les-essentials{% endif %}" class="mdl-campaign__link">Explore the Collection</a>
    </div>
    {%- if product.images.size > 3 -%}
    <div class="mdl-campaign__img mdl-campaign__img--half">
      <img src="{{ product.images[3] | image_url: width: 1200 }}" alt="{{ product.title }}" loading="lazy">
    </div>
    {%- endif -%}
  </div>
</section>

<!-- ============== SAMPLE PROMO BLOCK ============== -->
<section class="mdl-sample-promo">
  <div class="mdl-sample-promo__inner">
    <div class="mdl-sample-promo__text">
      <h2 class="mdl-sample-promo__title">Try It First, Love It Forever</h2>
      <p class="mdl-sample-promo__body">Every fragrance tells a story, revealed softly through time. A complimentary 2.5 ml sample accompanies each order — inviting you to explore before you commit. Trust your senses.</p>
      <a href="/products/discovery-set-larbre-de-vie" class="mdl-sample-promo__link">Explore the Discovery Set</a>
    </div>
    <div class="mdl-sample-promo__img">
      {%- assign disc = all_products['discovery-set-larbre-de-vie'] -%}
      {%- if disc != blank and disc.featured_image -%}
        <img src="{{ disc.featured_image | image_url: width: 800 }}" alt="L'Arbre de Vie Discovery Set" loading="lazy">
      {%- else -%}
        <div class="mdl-sample-promo__placeholder">
          <em>Discovery Set</em>
          <strong>L'Arbre de Vie</strong>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- ============== YOU MAY ALSO LIKE ============== -->
{%- assign related_collection = product.collections.first -%}
{%- if related_collection != blank and related_collection.products.size > 1 -%}
  <section class="mdl-related">
    <div class="mdl-related__head">
      <p class="mdl-related__eyebrow">From the same chapter</p>
      <h2 class="mdl-related__title">You May Also <em>Like</em></h2>
    </div>
    <div class="mdl-related__grid">
      {%- assign count = 0 -%}
      {%- for p in related_collection.products -%}
        {%- if p.id != product.id and count < 4 -%}
          <a href="{{ p.url }}" class="mdl-related__card">
            <div class="mdl-related__img">
              {%- if p.featured_image -%}
                <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title }}" loading="lazy">
              {%- else -%}
                <div class="mdl-related__placeholder">
                  <em>{{ related_collection.title }}</em>
                  <strong>{{ p.title }}</strong>
                </div>
              {%- endif -%}
            </div>
            <p class="mdl-related__name">{{ p.title }}</p>
            <p class="mdl-related__price">{{ p.price | money }}</p>
          </a>
          {%- assign count = count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

<script>
(function(){
  const form = document.getElementById('mdl-pdp-form');
  const priceEl = document.getElementById('mdl-pdp-price');
  const variantInput = document.getElementById('mdl-pdp-variant');
  const sampleSelect = document.getElementById('mdl-pdp-sample');
  const addBtn = document.getElementById('mdl-pdp-add');

  // Variant selection
  document.querySelectorAll('.mdl-pdp__variant').forEach(btn => {
    btn.addEventListener('click', function(){
      document.querySelectorAll('.mdl-pdp__variant').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      variantInput.value = this.getAttribute('data-id');
      // Update price (preserve schema meta tags)
      const newPrice = this.getAttribute('data-price-formatted');
      const metas = priceEl.querySelectorAll('meta');
      priceEl.textContent = newPrice;
      metas.forEach(m => priceEl.appendChild(m));
    });
  });

  // Add to cart with sample as line item property
  form.addEventListener('submit', function(e){
    e.preventDefault();
    addBtn.querySelector('span').textContent = 'Adding...';
    const payload = {
      id: variantInput.value,
      quantity: 1,
      properties: {
        'Complimentary Sample': sampleSelect ? sampleSelect.value : 'Surprise me — Maison\'s choice'
      }
    };
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(payload)
    })
    .then(r => r.json())
    .then(() => {
      addBtn.querySelector('span').textContent = 'Added ✓';
      if(window.mdlRefreshCart) window.mdlRefreshCart();
      setTimeout(() => {
        if(window.mdlOpenCart) window.mdlOpenCart();
        addBtn.querySelector('span').textContent = 'Add to Cart';
      }, 600);
    })
    .catch(() => {
      addBtn.querySelector('span').textContent = 'Add to Cart';
      alert('Something went wrong. Please try again.');
    });
  });
})();
</script>

{% schema %}
{ "name": "MDL Product", "settings": [] }
{% endschema %}
