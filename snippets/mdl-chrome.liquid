{{ 'homepage-mdl.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<div class="mdl-bar" id="mdl-bar">
  Complimentary samples with every order &nbsp;·&nbsp;
  <a href="/collections/larbre-de-vie">&nbsp;Discover L'Arbre de Vie →</a>
</div>

<header class="mdl-header solid" id="mdl-header" role="banner">
  <button class="mdl-header__burger" id="mdl-burger" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <nav class="mdl-header__nav-wrap" role="navigation" aria-label="Primary">
    <ul class="mdl-header__nav">
      <li><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></li>
      <li><a href="/collections/les-essentials">Les Essentials</a></li>
      <li><a href="/collections">Maison</a></li>
      <li><a href="/pages/about">L'Histoire</a></li>
    </ul>
  </nav>

  <div class="mdl-header__logo">
    <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
      <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}" alt="{{ shop.name }}" width="320" height="130" loading="eager">
    </a>
  </div>

  <div class="mdl-header__icons">
    <button class="mdl-header__icon" id="mdl-search-open" aria-label="Search">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
    </button>
    <button class="mdl-header__icon" id="mdl-cart-open" aria-label="Cart">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="mdl-cart-bubble" id="mdl-cart-count" {% if cart.item_count == 0 %}style="display:none"{% endif %}>{{ cart.item_count }}</span>
    </button>
  </div>
</header>

<!-- MOBILE NAV DRAWER — dropdown menu -->
<nav class="mdl-drawer" id="mdl-drawer" aria-label="Mobile navigation" aria-hidden="true">
  <button class="mdl-drawer__close" id="mdl-close" aria-label="Close menu">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <div class="mdl-drawer__inner">
    <div class="mdl-drawer__logo">
      <img src="{{ 'logo-musk-de-lumiere.png' | asset_url }}" alt="Musk de Lumière" width="140" height="60">
    </div>

    <!-- L'ARBRE DE VIE -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label"><a href="/collections/larbre-de-vie">L'Arbre de Vie</a></h4>

      <!-- The Roots dropdown -->
      <div class="mdl-drop">
        <button class="mdl-drop__toggle" aria-expanded="false" aria-controls="drop-roots">
          <span class="mdl-drop__title">The Roots <em class="mdl-drop__hint">De Bois</em></span>
          <svg class="mdl-drop__chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mdl-drop__body" id="drop-roots">
          <ul>
            {%- assign p1 = all_products['royale-oud'] -%}
            <li><a href="{% if p1 != blank and p1.id %}{{ p1.url }}{% else %}/collections/larbre-de-vie{% endif %}">Royale Oud</a></li>
            {%- assign p2 = all_products['cherie-oud'] -%}
            <li><a href="{% if p2 != blank and p2.id %}{{ p2.url }}{% else %}/collections/larbre-de-vie{% endif %}">Chérie Oud</a></li>
            {%- assign p3 = all_products['sultanat-oud'] -%}
            <li><a href="{% if p3 != blank and p3.id %}{{ p3.url }}{% else %}/collections/larbre-de-vie{% endif %}">Sultanat Oud</a></li>
            {%- assign p4 = all_products['imperiale-oud'] -%}
            <li><a href="{% if p4 != blank and p4.id %}{{ p4.url }}{% else %}/collections/larbre-de-vie{% endif %}">Impériale Oud</a></li>
            <li><a href="/collections/larbre-de-vie" class="mdl-drop__all">View all Roots <span>→</span></a></li>
          </ul>
        </div>
      </div>

      <!-- The Light dropdown -->
      <div class="mdl-drop">
        <button class="mdl-drop__toggle" aria-expanded="false" aria-controls="drop-light">
          <span class="mdl-drop__title">The Light <em class="mdl-drop__hint">Les Branches</em></span>
          <svg class="mdl-drop__chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mdl-drop__body" id="drop-light">
          <ul>
            {%- assign l1 = all_products['paradis-de-bleu'] -%}
            <li><a href="{% if l1 != blank and l1.id %}{{ l1.url }}{% else %}/collections/larbre-de-vie{% endif %}">Paradis de Bleu</a></li>
            {%- assign l2 = all_products['neroli-de-nuit'] -%}
            <li><a href="{% if l2 != blank and l2.id %}{{ l2.url }}{% else %}/collections/larbre-de-vie{% endif %}">Néroli de Nuit</a></li>
            {%- assign l3 = all_products['hayal'] -%}
            <li><a href="{% if l3 != blank and l3.id %}{{ l3.url }}{% else %}/collections/larbre-de-vie{% endif %}">Hayal</a></li>
            {%- assign l4 = all_products['rosee-blanche'] -%}
            <li><a href="{% if l4 != blank and l4.id %}{{ l4.url }}{% else %}/collections/larbre-de-vie{% endif %}">Rosée Blanche</a></li>
            <li><a href="/collections/larbre-de-vie" class="mdl-drop__all">View all Light <span>→</span></a></li>
          </ul>
        </div>
      </div>

      <!-- Discovery Set direct link -->
      <ul class="mdl-drawer__direct">
        {%- assign ds = all_products['discovery-set-larbre-de-vie'] -%}
        <li><a href="{% if ds != blank and ds.id %}{{ ds.url }}{% else %}/collections/larbre-de-vie{% endif %}">Discovery Set <em class="mdl-drawer__hint">8 × 2.5ml</em></a></li>
      </ul>
    </section>

    <!-- LES ESSENTIALS -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label"><a href="/collections/les-essentials">Les Essentials</a></h4>

      <div class="mdl-drop">
        <button class="mdl-drop__toggle" aria-expanded="false" aria-controls="drop-everyday">
          <span class="mdl-drop__title">Everyday <em class="mdl-drop__hint">10ml & 100ml</em></span>
          <svg class="mdl-drop__chev" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mdl-drop__body" id="drop-everyday">
          <ul>
            {%- assign e1 = all_products['prism'] -%}
            <li><a href="{% if e1 != blank and e1.id %}{{ e1.url }}{% else %}/collections/les-essentials{% endif %}">Prism</a></li>
            {%- assign e2 = all_products['bel-homme'] -%}
            <li><a href="{% if e2 != blank and e2.id %}{{ e2.url }}{% else %}/collections/les-essentials{% endif %}">Bel Homme</a></li>
            {%- assign e3 = all_products['madam-alece'] -%}
            <li><a href="{% if e3 != blank and e3.id %}{{ e3.url }}{% else %}/collections/les-essentials{% endif %}">Madam Alece</a></li>
            {%- assign e4 = all_products['fleur-rouge'] -%}
            <li><a href="{% if e4 != blank and e4.id %}{{ e4.url }}{% else %}/collections/les-essentials{% endif %}">Fleur Rouge</a></li>
            <li><a href="/collections/les-essentials" class="mdl-drop__all">View all Essentials <span>→</span></a></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- COMING SOON -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label">Coming Soon</h4>
      <ul class="mdl-drawer__direct">
        <li><span class="mdl-drawer__coming">Gift Sets <em>Soon</em></span></li>
        <li><span class="mdl-drawer__coming">Home Fragrances <em>Soon</em></span></li>
        <li><span class="mdl-drawer__coming">Essentials Discovery <em>Soon</em></span></li>
      </ul>
    </section>

    <!-- MAISON -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label">Maison</h4>
      <ul class="mdl-drawer__direct">
        <li><a href="/pages/about">Our Story <em class="mdl-drawer__hint">L'Histoire</em></a></li>
        <li><a href="/pages/the-craft">The Craft</a></li>
        <li><a href="/pages/journal">Journal</a></li>
        <li><a href="/pages/contact">Contact</a></li>
      </ul>
    </section>

    <!-- SERVICE -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label">Service</h4>
      <ul class="mdl-drawer__direct">
        <li><a href="/policies/shipping-policy">Shipping</a></li>
        <li><a href="/policies/refund-policy">Returns</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
      </ul>
    </section>

    <!-- LEGAL -->
    <section class="mdl-drawer__sec">
      <h4 class="mdl-drawer__label">Legal</h4>
      <ul class="mdl-drawer__legal">
        <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
        <li><a href="/policies/terms-of-service">Terms of Service</a></li>
      </ul>
    </section>

    <!-- ACCOUNT + CART -->
    <div class="mdl-drawer__foot">
      <a href="/account" class="mdl-drawer__util">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
        Account
      </a>
      <a href="/cart" class="mdl-drawer__util">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Cart <span class="mdl-drawer__util-count">({{ cart.item_count }})</span>
      </a>
    </div>
  </div>
</nav>

<div class="mdl-search-overlay" id="mdl-search">
  <button class="mdl-search-overlay__close" id="mdl-search-close" aria-label="Close search">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <form class="mdl-search-overlay__form" action="/search" method="get" role="search">
    <input type="hidden" name="type" value="product">
    <input class="mdl-search-overlay__input" type="search" name="q" placeholder="Search the Maison..." autocomplete="off" id="mdl-search-input" aria-label="Search products">
  </form>
  <div class="mdl-search-overlay__results">
    <p class="mdl-search-overlay__hint" id="mdl-search-hint">Start typing to discover fragrances</p>
    <div id="mdl-search-results"></div>
  </div>
</div>

<div class="mdl-cart-drawer__overlay" id="mdl-cart-overlay"></div>
<aside class="mdl-cart-drawer" id="mdl-cart-drawer" aria-label="Shopping cart">
  <div class="mdl-cart-drawer__head">
    <h2 class="mdl-cart-drawer__title">Your Cart</h2>
    <button class="mdl-cart-drawer__close" id="mdl-cart-close" aria-label="Close cart">
      <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="mdl-cart-drawer__body" id="mdl-cart-body">
    <div class="mdl-cart-drawer__empty">
      <p>Your cart awaits.</p>
      <a href="/collections/larbre-de-vie">Discover the Maison →</a>
    </div>
  </div>
  <div class="mdl-cart-drawer__foot" id="mdl-cart-foot" style="display:none;">
    <div class="mdl-cart-drawer__total">
      <span class="mdl-cart-drawer__total-label">Subtotal</span>
      <span class="mdl-cart-drawer__total-amount" id="mdl-cart-total">$0.00</span>
    </div>
    <a href="/checkout" class="mdl-cart-drawer__checkout">Checkout</a>
  </div>
</aside>

<script>
(function(){
  // iOS viewport height variable
  function setVh(){
    document.documentElement.style.setProperty('--mdl-vh', window.innerHeight + 'px');
  }
  setVh();
  window.addEventListener('resize', setVh);
  window.addEventListener('orientationchange', () => setTimeout(setVh, 250));

  const burger = document.getElementById('mdl-burger');
  const drawer = document.getElementById('mdl-drawer');
  const closeBtn = document.getElementById('mdl-close');

  burger.addEventListener('click', function(){
    drawer.classList.add('open');
    drawer.setAttribute('aria-hidden','false');
    burger.setAttribute('aria-expanded','true');
    document.body.style.overflow = 'hidden';
  });
  function closeDrawer(){
    drawer.classList.remove('open');
    drawer.setAttribute('aria-hidden','true');
    burger.setAttribute('aria-expanded','false');
    document.body.style.overflow = '';
  }
  closeBtn.addEventListener('click', closeDrawer);
  drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));

  // ====== DROPDOWN ACCORDIONS IN MENU ======
  document.querySelectorAll('.mdl-drop__toggle').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      const targetId = btn.getAttribute('aria-controls');
      const body = document.getElementById(targetId);
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      btn.setAttribute('aria-expanded', !isOpen);
      if(!isOpen){
        body.classList.add('open');
        // set max-height to actual content height for smooth animation
        body.style.maxHeight = body.scrollHeight + 'px';
      } else {
        body.style.maxHeight = '0';
        body.addEventListener('transitionend', function h(){
          body.classList.remove('open');
          body.removeEventListener('transitionend', h);
        });
      }
    });
  });


  // Search
  const searchOverlay = document.getElementById('mdl-search');
  const searchInput = document.getElementById('mdl-search-input');
  const searchResults = document.getElementById('mdl-search-results');
  const searchHint = document.getElementById('mdl-search-hint');
  let searchTimer = null;
  document.getElementById('mdl-search-open').addEventListener('click', function(){
    searchOverlay.classList.add('open');
    setTimeout(() => searchInput.focus(), 300);
  });
  document.getElementById('mdl-search-close').addEventListener('click', () => searchOverlay.classList.remove('open'));
  searchInput.addEventListener('input', function(e){
    clearTimeout(searchTimer);
    const q = e.target.value.trim();
    if(q.length < 2){ searchResults.innerHTML=''; searchHint.textContent='Start typing to discover fragrances'; return; }
    searchHint.textContent = 'Searching...';
    searchTimer = setTimeout(() => {
      fetch(`/search/suggest.json?q=${encodeURIComponent(q)}&resources[type]=product&resources[limit]=6`)
        .then(r => r.json())
        .then(data => {
          const products = data.resources.results.products || [];
          if(products.length === 0){ searchHint.textContent='No fragrances found'; searchResults.innerHTML=''; return; }
          searchHint.textContent = `${products.length} ${products.length === 1 ? 'result' : 'results'}`;
          searchResults.innerHTML = products.map(p => `
            <a href="${p.url}" class="mdl-search-result">
              ${p.image ? `<img src="${p.image}" class="mdl-search-result__img" alt="${p.title}">` : '<div class="mdl-search-result__img"></div>'}
              <div><div class="mdl-search-result__name">${p.title}</div><div class="mdl-search-result__price">${p.price}</div></div>
            </a>`).join('');
        });
    }, 250);
  });

  // Cart
  const cartDrawer = document.getElementById('mdl-cart-drawer');
  const cartOverlay = document.getElementById('mdl-cart-overlay');
  const cartBody = document.getElementById('mdl-cart-body');
  const cartFoot = document.getElementById('mdl-cart-foot');
  const cartTotal = document.getElementById('mdl-cart-total');
  const cartCount = document.getElementById('mdl-cart-count');
  function fmt(c){ return '$' + (c/100).toFixed(2); }
  function fetchCart(){ fetch('/cart.js').then(r => r.json()).then(renderCart); }
  function renderCart(cart){
    if(cartCount){ cartCount.textContent = cart.item_count; cartCount.style.display = cart.item_count > 0 ? 'flex' : 'none'; }
    if(cart.item_count === 0){
      cartBody.innerHTML = `<div class="mdl-cart-drawer__empty"><p>Your cart awaits.</p><a href="/collections/larbre-de-vie">Discover the Maison →</a></div>`;
      cartFoot.style.display = 'none'; return;
    }
    cartBody.innerHTML = cart.items.map(item => `
      <div class="mdl-cart-item" data-key="${item.key}">
        ${item.image ? `<img src="${item.image}" alt="${item.product_title}">` : '<div></div>'}
        <div class="mdl-cart-item__info">
          <div class="mdl-cart-item__name">${item.product_title}</div>
          <div class="mdl-cart-item__variant">${item.variant_title || ''}</div>
          <div class="mdl-cart-item__row">
            <div class="mdl-cart-item__qty">
              <button data-act="dec" data-key="${item.key}">−</button>
              <span>${item.quantity}</span>
              <button data-act="inc" data-key="${item.key}">+</button>
            </div>
            <div class="mdl-cart-item__price">${fmt(item.line_price)}</div>
          </div>
          <button class="mdl-cart-item__remove" data-act="rm" data-key="${item.key}">Remove</button>
        </div>
      </div>`).join('');
    cartTotal.textContent = fmt(cart.total_price);
    cartFoot.style.display = 'block';
    cartBody.querySelectorAll('button[data-act]').forEach(btn => {
      btn.addEventListener('click', function(){
        const key = this.getAttribute('data-key');
        const act = this.getAttribute('data-act');
        const item = cartBody.querySelector(`.mdl-cart-item[data-key="${key}"]`);
        const cur = parseInt(item.querySelector('.mdl-cart-item__qty span').textContent);
        let q = cur;
        if(act==='inc') q=cur+1; if(act==='dec') q=Math.max(0,cur-1); if(act==='rm') q=0;
        fetch('/cart/change.js', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:key,quantity:q})}).then(r=>r.json()).then(renderCart);
      });
    });
  }
  function openCart(){ cartDrawer.classList.add('open'); cartOverlay.classList.add('open'); fetchCart(); }
  function closeCart(){ cartDrawer.classList.remove('open'); cartOverlay.classList.remove('open'); }
  document.getElementById('mdl-cart-open').addEventListener('click', openCart);
  document.getElementById('mdl-cart-close').addEventListener('click', closeCart);
  cartOverlay.addEventListener('click', closeCart);
  fetchCart();
  window.mdlOpenCart = openCart;
  window.mdlRefreshCart = fetchCart;
})();
</script>
